---
type SectionProps = {
  title: string
  description?: string
  class?: string
}

const { title, description, class: className } = Astro.props as SectionProps
---

<section class:list={['mt-10', className]}>
  <h2 class="text-on-surface mb-5 text-lg font-semibold tracking-wide">
    {title}
  </h2>

  {
    description && (
      <p class="text-on-surface-variant mx-auto mb-4 max-w-prose text-sm">
        {description}
      </p>
    )
  }

  <div class="flex flex-col items-center gap-3">
    <slot />
  </div>
</section>

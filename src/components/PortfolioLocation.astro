---
import { ArrowUpRight, MapPin } from 'lucide-react'
import { buttonVariants } from './ui/button'

type Props = {
  title: string
  address: string
  latitude: number
  longitude: number
  plusCode: string
  googleMapsUrl: string
}

const { title, address, latitude, longitude, plusCode, googleMapsUrl } =
  Astro.props

const [streetAddress, ...localityParts] = address.split(', ')
const locality = localityParts.join(', ')
const longitudeOffset = 0.008
const latitudeOffset = 0.005
const mapUrl = new URL('https://www.openstreetmap.org/export/embed.html')

mapUrl.searchParams.set(
  'bbox',
  [
    longitude - longitudeOffset,
    latitude - latitudeOffset,
    longitude + longitudeOffset,
    latitude + latitudeOffset,
  ].join(','),
)
mapUrl.searchParams.set('layer', 'mapnik')
mapUrl.searchParams.set('marker', `${latitude},${longitude}`)
---

<section
  class="border-border mx-auto max-w-4xl border-t py-8 sm:py-10"
  aria-labelledby="location-title"
>
  <div
    class="bg-muted/35 ring-border/70 grid overflow-hidden ring-1 md:grid-cols-[minmax(0,1.2fr)_minmax(20rem,0.8fr)]"
  >
    <div class="bg-muted relative min-h-72 overflow-hidden md:min-h-80">
      <iframe
        src={mapUrl.toString()}
        title={`Map showing ${title} at ${address}`}
        width="800"
        height="500"
        loading="lazy"
        class="absolute inset-0 size-full border-0 contrast-[.92] saturate-[.55] transition-[filter] duration-300 hover:saturate-75 focus:saturate-75 dark:brightness-[.8] dark:contrast-[1.05]"
      >
      </iframe>
    </div>

    <div
      class="bg-card/85 flex flex-col justify-between gap-10 px-6 py-8 sm:px-8 sm:py-10"
    >
      <div>
        <div class="text-primary mb-5 flex items-center gap-2">
          <MapPin className="size-4" aria-hidden="true" />
          <span class="text-xs font-bold tracking-[0.16em] uppercase">
            Location
          </span>
        </div>
        <h2
          id="location-title"
          class="font-heading text-2xl font-bold sm:text-3xl"
        >
          {title}
        </h2>
        <address
          class="text-foreground mt-5 max-w-[28ch] text-lg leading-7 font-medium not-italic"
        >
          <span class="block">{streetAddress}</span>
          {
            locality && (
              <span class="text-muted-foreground mt-1 block text-base font-normal">
                {locality}
              </span>
            )
          }
        </address>
        <p class="text-muted-foreground mt-5 text-xs leading-5">
          <span class="block font-semibold tracking-wider uppercase">
            Plus Code
          </span>
          <span class="text-foreground/80 mt-0.5 block">{plusCode}</span>
        </p>
      </div>

      <a
        href={googleMapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class={buttonVariants({
          variant: 'outline',
          size: 'lg',
          className:
            'h-10 w-fit rounded-none px-4 font-semibold shadow-none dark:bg-transparent',
        })}
      >
        Open in Google Maps
        <ArrowUpRight
          data-icon="inline-end"
          className="size-4"
          aria-hidden="true"
        />
      </a>
    </div>
  </div>
</section>

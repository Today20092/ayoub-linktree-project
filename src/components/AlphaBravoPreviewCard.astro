---
import { badgeVariants } from '@/components/ui/badge'
import { buttonVariants } from '@/components/ui/button'

const href = 'https://alphabravomedia.co'

const baseBadgeClass = 'h-7 px-3 text-xs font-bold shadow-sm'
const cardBadgeClass = badgeVariants({
  variant: 'outline',
  className: baseBadgeClass,
})
const primaryBadgeClass = badgeVariants({
  className: baseBadgeClass,
})
const arrowButtonClass = buttonVariants({
  size: 'icon-lg',
  className:
    'size-11 rounded-full transition-transform duration-300 group-hover/card:translate-x-1 sm:size-14',
})
---

<a
  href={href}
  id="alphabravomedia"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="AlphaBravoMedia homepage preview"
  data-slot="card"
  data-size="default"
  class="group/card bg-card text-card-foreground ring-foreground/10 focus-visible:border-ring focus-visible:ring-ring/30 mx-auto flex w-full max-w-[560px] flex-col gap-4 overflow-hidden rounded-xl py-4 text-sm ring-1 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg focus-visible:ring-3 focus-visible:outline-none active:translate-y-0 sm:gap-5 sm:py-5"
>
  <span data-slot="card-content" class="px-4 sm:px-5">
    <span
      class="bg-muted ring-border/70 relative block aspect-[16/10] overflow-hidden rounded-lg ring-1"
    >
      <img
        src="/previews/alphabravomedia-homepage.png"
        alt=""
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover object-[35%_18%] transition-transform duration-500 group-hover/card:scale-[1.03]"
      />
      <span
        class="from-card via-card/75 absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t to-transparent"
        aria-hidden="true"
      >
      </span>
      <span
        class="absolute right-3 bottom-3 left-3 flex flex-wrap items-center gap-2"
      >
        <span
          data-slot="badge"
          data-variant="default"
          class={primaryBadgeClass}
        >
          Pricing
        </span>
        <span data-slot="badge" data-variant="outline" class={cardBadgeClass}>
          Portfolio
        </span>
        <span data-slot="badge" data-variant="outline" class={cardBadgeClass}>
          Client work
        </span>
      </span>
    </span>
  </span>

  <span
    data-slot="card-footer"
    class="bg-muted/50 flex items-center justify-between gap-3 border-t px-4 pt-4 text-center sm:px-5 sm:pt-5"
  >
    <span class="flex-1 text-center">
      <span
        data-slot="card-title"
        class="font-heading text-card-foreground block text-lg leading-tight font-medium sm:text-xl"
      >
        See our work at AlphaBravoMedia
      </span>
      <span
        data-slot="card-description"
        class="text-muted-foreground block text-sm"
      >
        View portfolio, pricing, and media services
      </span>
    </span>
    <span
      data-slot="button"
      data-variant="default"
      data-size="icon-lg"
      class={arrowButtonClass}
    >
      <span aria-hidden="true">→</span>
    </span>
  </span>
</a>

---
const href = 'https://alphabravomedia.co'
---

<a
  href={href}
  id="alphabravomedia"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="AlphaBravoMedia homepage preview"
  class="group border-outline-variant/70 bg-surface-container-high text-company elevation-2 hover:elevation-4 focus-visible:ring-primary/70 focus-visible:ring-offset-surface mx-auto block w-full max-w-[560px] overflow-hidden rounded-2xl border transition-all duration-300 ease-out hover:-translate-y-1 hover:scale-[1.01] hover:brightness-105 focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none active:translate-y-0 active:scale-[0.99]"
>
  <span class="block p-3 sm:p-4">
    <span
      class="border-outline-variant/60 relative block aspect-[16/10] overflow-hidden rounded-xl border bg-[#f7f3ea] shadow-inner"
    >
      <img
        src="/previews/alphabravomedia-homepage.png"
        alt=""
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover object-[35%_18%] transition-transform duration-500 group-hover:scale-[1.03]"
      />
      <span
        class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-[#f6efe6] via-[#f6efe6]/75 to-transparent"
        aria-hidden="true"
      >
      </span>
      <span
        class="absolute right-3 bottom-3 left-3 flex flex-wrap items-center gap-2"
      >
        <span
          class="rounded-full bg-[#c76533] px-3 py-1.5 text-xs font-bold text-white shadow-md"
        >
          Pricing
        </span>
        <span
          class="rounded-full bg-white/90 px-3 py-1.5 text-xs font-bold text-[#3b3028] shadow-md ring-1 ring-[#d7c9ba]"
        >
          Portfolio
        </span>
        <span
          class="rounded-full bg-white/90 px-3 py-1.5 text-xs font-bold text-[#3b3028] shadow-md ring-1 ring-[#d7c9ba]"
        >
          Client work
        </span>
      </span>
    </span>

    <span class="flex items-center justify-between gap-3 px-1 pt-4">
      <span class="text-left">
        <span class="text-on-surface block text-lg leading-tight font-bold">
          AlphaBravoMedia Homepage
        </span>
        <span class="text-on-surface-variant block text-sm">
          Preview of the content-retainer homepage
        </span>
      </span>
      <span
        class="bg-company text-surface grid h-11 w-11 shrink-0 place-items-center rounded-full transition-transform duration-300 group-hover:translate-x-1"
      >
        <span aria-hidden="true">→</span>
      </span>
    </span>
  </span>
</a>

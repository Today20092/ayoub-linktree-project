---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import { CalendarDays, Camera, Clock, MapPin } from 'lucide-react'

import UpcomingVideo from './UpcomingVideo'
import { Badge } from './ui/badge'
import {
  Empty,
  EmptyDescription,
  EmptyHeader,
  EmptyMedia,
  EmptyTitle,
} from './ui/empty'
import { Skeleton } from './ui/skeleton'

type Props = {
  flyer: ImageMetadata
  flyerAlt: string
  date: string
  time?: string
  venue?: string
  upcomingVideo?: {
    label: string
    title: string
    description: string
  }
}

const { flyer, flyerAlt, date, time, venue, upcomingVideo } = Astro.props
---

<section
  class="mt-10 grid gap-8 lg:grid-cols-[minmax(18rem,0.72fr)_minmax(0,1.28fr)] lg:items-start"
>
  <Image
    src={flyer}
    alt={flyerAlt}
    widths={[480, 720, 960]}
    sizes="(min-width: 1024px) 36vw, 100vw"
    quality={85}
    class="bg-muted w-full rounded-2xl border object-cover shadow-sm"
  />

  <div class="flex flex-col gap-6">
    <div class="flex flex-wrap gap-2" aria-label="Event details">
      <Badge variant="secondary">
        <CalendarDays aria-hidden="true" />
        {date}
      </Badge>
      {
        time && (
          <Badge variant="outline">
            <Clock aria-hidden="true" />
            {time}
          </Badge>
        )
      }
      {
        venue && (
          <Badge variant="outline">
            <MapPin aria-hidden="true" />
            {venue}
          </Badge>
        )
      }
    </div>

    <Empty className="border-border bg-muted/30 min-h-64 border">
      <EmptyHeader>
        <EmptyMedia variant="icon">
          <Camera aria-hidden="true" />
        </EmptyMedia>
        <EmptyTitle>Event photos coming soon</EmptyTitle>
        <EmptyDescription>
          I’ll add the photographs here after the event. Save this page and
          check back for the finished gallery.
        </EmptyDescription>
      </EmptyHeader>
    </Empty>

    <div class="grid grid-cols-3 gap-3" aria-hidden="true">
      <Skeleton className="aspect-[4/3] rounded-xl" />
      <Skeleton className="aspect-[4/3] rounded-xl" />
      <Skeleton className="aspect-[4/3] rounded-xl" />
    </div>

    {upcomingVideo && <UpcomingVideo {...upcomingVideo} />}
  </div>
</section>

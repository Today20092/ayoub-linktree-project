---
const token =
  import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN ??
  '76b32a2fd3844a56b8cb4ffa60ab45a6'
---

{
  token && (
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={JSON.stringify({ token })}
    />
  )
}

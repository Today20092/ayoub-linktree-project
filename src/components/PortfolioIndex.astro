---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import simpleIcons from '@iconify-json/simple-icons/icons.json'
import { IdCard, MessageSquareText, Share2 } from 'lucide-react'

import keetIcon from '@/assets/keet.svg?raw'
import { buttonVariants } from '@/components/ui/button'
import { cn } from '@/lib/utils'

type LinkItem = {
  id: string
  label: string
  url: string
  icon?: string
  iconUrl?: string
}

type Channel = {
  id: string
  name: string
  videosUrl: string
}

type PortfolioCard = {
  slug: string
  title: string
  category: string
  thumbnail: ImageMetadata | string
  imageAlt: string
  imageWidth: number
  imageHeight: number
}

type Props = {
  pageDescription: string
  shareTitle: string
  shareText: string
  shareUrl: string
  currentYear: number
  primaryLinks: LinkItem[]
  socialLinks: LinkItem[]
  supportLinks: LinkItem[]
  channels: Channel[]
  projects: PortfolioCard[]
}

const {
  pageDescription,
  shareTitle,
  shareText,
  shareUrl,
  currentYear,
  primaryLinks,
  socialLinks,
  supportLinks,
  channels,
  projects,
} = Astro.props as Props

const simpleIconBody = (name?: string) =>
  simpleIcons.icons[
    name?.replace('simple-icons:', '') as keyof typeof simpleIcons.icons
  ]?.body ?? ''
---

<main
  id="main-content"
  class="mx-auto w-full max-w-screen-2xl px-4 py-6 text-left sm:px-6 sm:py-8 lg:px-8"
>
  <header class="border-border border-b pb-8 lg:pb-12">
    <div
      class="grid grid-cols-2 gap-x-6 gap-y-8 lg:grid-cols-12 lg:items-start lg:gap-y-10"
    >
      <div
        class="col-span-2 flex min-w-0 items-start justify-between gap-3 lg:col-span-3 lg:row-start-1"
        data-reveal="fade"
      >
        <div class="min-w-0">
          <h1 class="font-heading text-foreground text-base font-extrabold">
            Ayoub Abedrabbo
          </h1>
          <p
            class="text-muted-foreground mt-2 text-xs font-semibold tracking-wider uppercase"
          >
            Digital media specialist
          </p>
        </div>
        <div class="flex shrink-0 flex-col items-end">
          <button
            id="share-site"
            type="button"
            data-share-title={shareTitle}
            data-share-text={shareText}
            data-share-url={shareUrl}
            class={cn(
              buttonVariants({ variant: 'ghost', size: 'lg' }),
              'min-h-11 rounded-sm px-3 text-sm font-bold',
            )}
          >
            <Share2 data-icon="inline-start" aria-hidden="true" />
            <span>Share</span>
          </button>
          <span
            id="share-status"
            class="text-muted-foreground mt-1 min-h-4 text-xs"
            aria-live="polite"
          >
          </span>
        </div>
      </div>

      <div
        class="col-span-2 lg:col-span-5 lg:row-start-1"
        data-reveal="up"
        style="--reveal-delay: 70ms"
      >
        <p
          class="text-muted-foreground mb-2 text-xs font-semibold tracking-wider uppercase"
        >
          About
        </p>
        <p
          class="text-foreground max-w-2xl text-sm leading-6 font-semibold sm:text-base sm:leading-7"
        >
          {pageDescription}
        </p>
      </div>

      <nav
        id="contact"
        class="col-span-2 scroll-mt-20 lg:col-span-4 lg:row-start-1"
        aria-label="Contact links"
        data-reveal="up"
        style="--reveal-delay: 140ms"
      >
        <p
          class="text-muted-foreground text-xs font-semibold tracking-wider uppercase"
        >
          Contact
        </p>
        <p class="text-muted-foreground mt-1 text-sm leading-5">
          Meeting me in person? Save my contact, then text me your name.
        </p>
        <ol class="mt-3 flex w-full flex-col gap-3">
          {
            primaryLinks.map((link, index) => (
              <li>
                <a
                  href={link.url}
                  class={cn(
                    buttonVariants({
                      variant: index === 0 ? 'default' : 'outline',
                      size: 'lg',
                    }),
                    'focus-visible:ring-offset-background h-auto min-h-12 w-full justify-start gap-3 rounded-sm px-3 py-2.5 text-base leading-5 font-bold whitespace-normal focus-visible:ring-offset-2',
                  )}
                >
                  {link.id === 'contact' ? (
                    <IdCard data-icon="inline-start" aria-hidden="true" />
                  ) : (
                    <MessageSquareText
                      data-icon="inline-start"
                      aria-hidden="true"
                    />
                  )}
                  <span class="min-w-0">{link.label}</span>
                </a>
                <p class="text-muted-foreground mt-1 px-3 text-xs leading-5">
                  {index === 0
                    ? 'Phone, email, and website.'
                    : 'So I can save your number too.'}
                </p>
              </li>
            ))
          }
        </ol>
      </nav>

      <nav
        class="col-span-2 lg:col-span-3 lg:col-start-4 lg:row-start-2"
        aria-label="YouTube channels"
        data-reveal="up"
        style="--reveal-delay: 210ms"
      >
        <p
          class="text-muted-foreground mb-2 text-xs font-semibold tracking-wider uppercase"
        >
          Channels
        </p>
        <div class="flex flex-col text-base font-bold">
          {
            channels.map((channel) => (
              <a
                href={channel.videosUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-foreground hover:bg-accent hover:text-accent-foreground focus-visible:ring-ring grid min-h-12 w-full grid-cols-[1.25rem_minmax(0,1fr)] items-center gap-3 rounded-sm px-2 underline decoration-dotted underline-offset-4 transition-[color,background-color,transform] focus-visible:ring-2 focus-visible:outline-none active:scale-[0.98]"
              >
                <span
                  class="inline-flex size-5 items-center justify-center"
                  aria-hidden="true"
                >
                  <svg
                    class="size-5"
                    viewBox="0 0 24 24"
                    set:html={simpleIconBody('simple-icons:youtube')}
                  />
                </span>
                <span>{channel.name}</span>
              </a>
            ))
          }
        </div>
      </nav>

      <nav
        class="col-span-2 lg:col-span-6 lg:col-start-7 lg:row-start-2"
        aria-label="Social links"
        data-reveal="up"
        style="--reveal-delay: 280ms"
      >
        <p
          class="text-muted-foreground mb-2 text-xs font-semibold tracking-wider uppercase"
        >
          Social
        </p>
        <div
          class="grid grid-cols-1 gap-x-4 text-base font-bold sm:grid-cols-2"
        >
          {
            socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-foreground hover:bg-accent hover:text-accent-foreground focus-visible:ring-ring grid min-h-12 min-w-0 grid-cols-[1.25rem_minmax(0,1fr)] items-center gap-3 rounded-sm px-2 underline decoration-dotted underline-offset-4 transition-[color,background-color,transform] focus-visible:ring-2 focus-visible:outline-none active:scale-[0.98]"
              >
                <span
                  class="inline-flex size-5 items-center justify-center [&_svg]:size-5"
                  aria-hidden="true"
                >
                  {link.id === 'keet' ? (
                    <Fragment set:html={keetIcon} />
                  ) : link.iconUrl ? (
                    <Image
                      src={link.iconUrl}
                      alt=""
                      width={107}
                      height={117}
                      class="size-5"
                    />
                  ) : (
                    <svg
                      class="size-5"
                      viewBox="0 0 24 24"
                      set:html={simpleIconBody(link.icon)}
                    />
                  )}
                </span>
                <span>{link.label}</span>
              </a>
            ))
          }
        </div>
      </nav>
    </div>
  </header>

  <section id="portfolio" class="scroll-mt-6 pt-10 lg:pt-16" data-reveal="fade">
    <h2 class="sr-only">Portfolio</h2>
    <div class="columns-1 gap-4 space-y-8 md:columns-2 lg:gap-6 xl:columns-3">
      {
        projects.map((project, index) => (
          <article
            class="break-inside-avoid"
            data-reveal="up"
            style={`--reveal-delay: ${Math.min(index, 8) * 45}ms`}
          >
            <a
              href={`/portfolio/${project.slug}/`}
              class="group focus-visible:ring-ring block rounded-sm focus-visible:ring-2 focus-visible:ring-offset-4 focus-visible:outline-none"
            >
              {typeof project.thumbnail === 'string' ? (
                <Image
                  src={project.thumbnail}
                  alt={project.imageAlt}
                  width={project.imageWidth}
                  height={project.imageHeight}
                  layout="constrained"
                  widths={[480, 720, 960]}
                  sizes="(min-width: 1280px) 30vw, (min-width: 768px) 48vw, 100vw"
                  quality={80}
                  priority={index === 0}
                  class="bg-muted block h-auto w-full transition-[opacity,transform] duration-300 ease-out group-hover:scale-[1.015] group-hover:opacity-90"
                />
              ) : (
                <Image
                  src={project.thumbnail}
                  alt={project.imageAlt}
                  width={project.imageWidth}
                  height={project.imageHeight}
                  layout="constrained"
                  widths={[480, 720, 960]}
                  sizes="(min-width: 1280px) 30vw, (min-width: 768px) 48vw, 100vw"
                  quality={80}
                  priority={index === 0}
                  class="bg-muted block h-auto w-full transition-[opacity,transform] duration-300 ease-out group-hover:scale-[1.015] group-hover:opacity-90"
                />
              )}
              <span class="mt-3 block">
                <strong class="font-heading text-foreground block text-base leading-5 font-extrabold">
                  {project.title}
                </strong>
                <small class="text-muted-foreground mt-1 block text-xs font-medium tracking-wider uppercase">
                  {project.category}
                </small>
              </span>
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <footer
    class="border-border text-muted-foreground mt-16 flex flex-col gap-8 border-t py-8 text-sm sm:flex-row sm:items-end sm:justify-between lg:mt-24"
    data-reveal="fade"
  >
    <div>
      <p class="mb-3 text-xs font-semibold tracking-wider uppercase">Support</p>
      <nav
        class="flex flex-wrap gap-x-6 gap-y-3"
        aria-label="Support and payment links"
      >
        {
          supportLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-foreground hover:bg-accent hover:text-accent-foreground focus-visible:ring-ring inline-flex min-h-12 items-center gap-3 rounded-sm px-2 text-base font-bold underline decoration-dotted underline-offset-4 transition-[color,background-color,transform] focus-visible:ring-2 focus-visible:outline-none active:scale-[0.98]"
            >
              {link.icon && (
                <svg
                  class="size-5"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  set:html={simpleIconBody(link.icon)}
                />
              )}
              <span>{link.label}</span>
            </a>
          ))
        }
      </nav>
    </div>
    <p>&copy; {currentYear} Ayoub Abedrabbo</p>
  </footer>
</main>

<script>
  const shareButton = document.querySelector<HTMLButtonElement>('#share-site')
  const shareStatus = document.querySelector<HTMLElement>('#share-status')

  shareButton?.addEventListener('click', async () => {
    const shareData = {
      title: shareButton.dataset.shareTitle ?? document.title,
      text: shareButton.dataset.shareText ?? '',
      url: shareButton.dataset.shareUrl ?? window.location.href,
    }

    shareStatus?.replaceChildren()

    if (navigator.share) {
      try {
        await navigator.share(shareData)
        return
      } catch (error) {
        if (error instanceof DOMException && error.name === 'AbortError') return
      }
    }

    try {
      await navigator.clipboard.writeText(shareData.url)
      shareStatus?.append('Link copied.')
    } catch {
      shareStatus?.append('Share ayoubabed.xyz')
    }
  })
</script>

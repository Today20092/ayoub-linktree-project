---
import { Icon } from 'astro-icon/components'

import latestYoutubeVideos from '../data/latest-youtube-videos.json'

type GeneratedYoutubeVideo = {
  videoId: string
  title: string
  url: string
  thumbnail: string
}

type CarouselImage = {
  src: string
  alt: string
  href: string
}

const carouselImages = Object.values(latestYoutubeVideos)
  .flatMap(
    (channel) => (channel as { videos?: GeneratedYoutubeVideo[] }).videos ?? [],
  )
  .map(
    (video): CarouselImage => ({
      src: video.thumbnail,
      alt: video.title || 'Ayoub YouTube video thumbnail',
      href:
        video.url || `https://www.youtube.com/watch?v=${video.videoId}`,
    }),
  )

const rowCount = 3
const bentoRows = Array.from({ length: rowCount }, (_, rowIndex) =>
  carouselImages.filter((_, index) => index % rowCount === rowIndex),
).filter((row) => row.length > 0)
---

{
  carouselImages.length > 0 && (
    <section
      class="animate-fade-in-up mx-auto mt-6 w-full max-w-xl px-4 delay-300 sm:px-6"
      aria-labelledby="latest-videos-title"
    >
      <div class="mb-4 text-left">
        <p class="text-primary text-xs font-bold tracking-[0.18em] uppercase">
          Watch
        </p>
        <h2
          id="latest-videos-title"
          class="text-foreground mt-1 text-2xl font-extrabold"
        >
          Latest videos
        </h2>
        <p class="text-muted-foreground mt-1 text-sm leading-relaxed">
          Tap any thumbnail to watch on YouTube.
        </p>
      </div>
      <div class="border-border/70 bg-muted text-foreground dark:border-border dark:bg-muted overflow-hidden rounded-xl border shadow-[0_18px_42px_oklch(0.35_0.045_70_/_0.14)]">
        <div class="bento-scroll-mask flex flex-col gap-2 overflow-hidden p-3 sm:gap-3">
          {bentoRows.map((row, rowIndex) => (
            <div class="bento-scroll-row overflow-hidden">
              <div
                class:list={[
                  'bento-scroll-track flex w-max gap-2 sm:gap-3',
                  `bento-scroll-track-${rowIndex + 1}`,
                ]}
              >
                {[...row, ...row].map((item) => (
                  <a
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Watch on YouTube: ${item.alt}`}
                    class="group bg-accent focus-visible:outline-ring dark:bg-accent relative isolate block aspect-video w-[252px] shrink-0 overflow-hidden rounded-lg border border-border/60 text-left shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-lg focus-visible:outline-3 focus-visible:outline-offset-2 sm:w-[274px] dark:border-border"
                  >
                    <img
                      src={item.src}
                      alt={item.alt}
                      width="480"
                      height="270"
                      class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                      loading="lazy"
                      decoding="async"
                    />
                    <span
                      class="absolute inset-0 bg-foreground/0 transition duration-200 group-hover:bg-foreground/10 group-focus-visible:bg-foreground/10"
                      aria-hidden="true"
                    ></span>
                    <span
                      class="absolute right-2 bottom-2 grid size-9 place-items-center rounded-full bg-background/90 text-primary opacity-80 shadow-lg ring-1 ring-border backdrop-blur-sm transition duration-200 group-hover:scale-105 group-hover:opacity-100 group-focus-visible:scale-105 group-focus-visible:opacity-100 dark:bg-background/85"
                      aria-hidden="true"
                    >
                      <Icon
                        name="heroicons:play-solid"
                        class="size-4 translate-x-px"
                      />
                    </span>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<script>
  const marqueeMask = document.querySelector('.bento-scroll-mask')
  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches

  if (marqueeMask instanceof HTMLElement && !prefersReducedMotion) {
    const rows = [...marqueeMask.querySelectorAll('.bento-scroll-row')].map(
      (row, index) => {
        const track = row.querySelector('.bento-scroll-track')
        const baseDurations = [82, 98, 90]
        const width =
          track instanceof HTMLElement ? track.scrollWidth / 2 : 274 * 8

        return {
          row,
          track,
          x: 0,
          speed: -width / baseDurations[index % baseDurations.length],
          dragVelocity: 0,
        }
      },
    )

    let lastFrame = performance.now()
    let activeRow = null
    let activePointer = null
    let lastPointerX = 0
    let lastPointerTime = 0
    let dragDistance = 0

    const wrap = (value, width) => {
      if (!width) return value
      while (value <= -width) value += width
      while (value > 0) value -= width
      return value
    }

    const animate = (time) => {
      const delta = Math.min((time - lastFrame) / 1000, 0.05)
      lastFrame = time

      for (const state of rows) {
        if (!(state.track instanceof HTMLElement)) continue

        const width = state.track.scrollWidth / 2
        if (state !== activeRow) {
          state.x += (state.speed + state.dragVelocity) * delta
          state.dragVelocity *= Math.pow(0.08, delta)
        }

        state.x = wrap(state.x, width)
        state.track.style.transform = `translate3d(${state.x}px, 0, 0)`
      }

      requestAnimationFrame(animate)
    }

    marqueeMask.classList.add('is-drag-ready')
    requestAnimationFrame(animate)

    for (const state of rows) {
      state.row.addEventListener('pointerdown', (event) => {
        activeRow = state
        activePointer = event.pointerId
        lastPointerX = event.clientX
        lastPointerTime = performance.now()
        dragDistance = 0
        state.dragVelocity = 0
        state.row.setPointerCapture(event.pointerId)
      })

      state.row.addEventListener('pointermove', (event) => {
        if (activeRow !== state || activePointer !== event.pointerId) return

        const now = performance.now()
        const deltaX = event.clientX - lastPointerX
        const deltaTime = Math.max(now - lastPointerTime, 1)

        state.x += deltaX
        state.dragVelocity = (deltaX / deltaTime) * 1000
        dragDistance += Math.abs(deltaX)
        lastPointerX = event.clientX
        lastPointerTime = now
      })

      state.row.addEventListener('pointerup', (event) => {
        if (activeRow !== state || activePointer !== event.pointerId) return
        activeRow = null
        activePointer = null
      })

      state.row.addEventListener('pointercancel', () => {
        activeRow = null
        activePointer = null
      })

      state.row.addEventListener(
        'click',
        (event) => {
          if (dragDistance > 12) {
            event.preventDefault()
            event.stopPropagation()
          }
        },
        true,
      )
    }
  }
</script>

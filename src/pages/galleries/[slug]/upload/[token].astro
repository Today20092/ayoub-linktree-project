---
import '../../../../styles.css'

import { env } from 'cloudflare:workers'
import { ArrowLeft } from 'lucide-react'

import GuestUpload from '../../../../components/GuestUpload'
import { Button } from '../../../../components/ui/button'
import { galleryReader } from '../../../../lib/gallery-read'
import BaseLayout from '../../../../layouts/BaseLayout.astro'

export const prerender = false

const eventSlug = Astro.params.slug
const token = Astro.params.token
if (!eventSlug || !token) {
  return new Response(null, { status: 404 })
}

const context = await galleryReader(env.GALLERY_DB).getInviteContext(
  eventSlug,
  token,
)
if (!context) {
  return new Response(null, { status: 404 })
}
const { gallery, invite } = context
const eventTitle = gallery.title
const summary = gallery.summary
const ogImage = gallery.flyer?.src ?? gallery.featuredImageSrc ?? '/og.jpg'

Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow')
---

<BaseLayout
  title={`Upload photos for ${eventTitle}`}
  description={`Upload photos for ${eventTitle}.`}
  canonicalUrl={new URL(
    `/galleries/${eventSlug}/upload/${token}/`,
    Astro.site,
  ).toString()}
  ogImage={ogImage}
  ogImageAlt={`${eventTitle} upload`}
  activeNav="galleries"
>
  <main
    id="main-content"
    class="mx-auto w-full max-w-2xl scroll-mt-20 px-4 py-10 sm:px-6 sm:py-14"
  >
    <Button variant="ghost" size="sm" asChild>
      <a href={`/galleries/${eventSlug}/`}>
        <ArrowLeft data-icon="inline-start" aria-hidden="true" />
        Back to gallery
      </a>
    </Button>

    <header class="mt-8">
      <p class="text-primary text-sm font-bold tracking-wide uppercase">
        Guest upload
      </p>
      <h1
        class="font-heading mt-3 text-4xl leading-none font-extrabold tracking-tight sm:text-5xl"
      >
        Share photos for {eventTitle}
      </h1>
      <p class="text-muted-foreground mt-5 max-w-xl text-lg leading-8">
        This upload link is assigned to {invite.guest_name}. Photos publish to
        the gallery after upload.
      </p>
      {summary && <p class="text-muted-foreground mt-3 text-sm">{summary}</p>}
    </header>

    <div class="mt-8">
      <GuestUpload
        client:only="react"
        eventSlug={eventSlug}
        eventTitle={eventTitle}
        enabled
        inviteToken={token}
        guestName={invite.guest_name}
      />
    </div>
  </main>
</BaseLayout>

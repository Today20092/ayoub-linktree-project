---
import '../../../styles.css'

import { Image } from 'astro:assets'
import { ArrowRight, Heart, ImageUp } from 'lucide-react'
import { getEntry } from 'astro:content'
import { env } from 'cloudflare:workers'

import EventLightbox from '../../../components/EventLightbox'
import EventComingSoon from '../../../components/EventComingSoon.astro'
import FaceFinder from '../../../components/FaceFinder'
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from '../../../components/ui/breadcrumb'
import { Badge } from '../../../components/ui/badge'
import { Button } from '../../../components/ui/button'
import { eventGalleries } from '../../../data/event-galleries'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { faceManifests } from '../../../lib/face-manifests'
import {
  getEventGallery,
  getGallerySettings,
  getHiddenFilenames,
  listGalleryPhotos,
  listPublishedGuestPhotos,
  publicEventFlyer,
  publicGalleryPhoto,
  publicGuestPhoto,
} from '../../../lib/gallery-data'
import { siteConfig } from '../../../lib/site-config'

export const prerender = false

type RemoteGalleryImage = {
  src: string
  width: number
  height: number
  alt: string
  filename: string
  caption?: string
  featured?: boolean
}

const eventSlug = Astro.params.slug
const staticProject = eventSlug
  ? await getEntry('portfolio', eventSlug)
  : undefined
const project = staticProject?.data.eventGallery ? staticProject : undefined
const dynamicEvent = eventSlug
  ? await getEventGallery(env.GALLERY_DB, eventSlug)
  : undefined
if ((!project && !dynamicEvent) || !eventSlug) {
  return new Response(null, { status: 404 })
}
if (dynamicEvent?.status === 'hidden') {
  return new Response(null, { status: 404 })
}
const data = project?.data
const [hiddenFilenames, publishedGuests, gallerySettings, uploadedPhotos] =
  await Promise.all([
    getHiddenFilenames(env.GALLERY_DB, eventSlug),
    listPublishedGuestPhotos(env.GALLERY_DB, eventSlug),
    getGallerySettings(env.GALLERY_DB, eventSlug),
    listGalleryPhotos(env.GALLERY_DB, eventSlug),
  ])

const inlineImages = data
  ? data.gallery.filter(
      (
        image,
      ): image is Extract<
        (typeof data.gallery)[number],
        { filename: string }
      > => 'filename' in image,
    )
  : []
const fallbackImages = eventGalleries[eventSlug] ?? []
const rawImages: RemoteGalleryImage[] =
  inlineImages.length > 0
    ? (inlineImages as unknown as RemoteGalleryImage[])
    : fallbackImages

const dynamicComingSoon =
  dynamicEvent?.status === 'coming_soon' || Boolean(dynamicEvent?.coming_soon)
const uploadedImages = dynamicComingSoon
  ? []
  : uploadedPhotos.map(publicGalleryPhoto)
const adminUploadedImages = uploadedImages.filter(
  (image) => image.source === 'admin',
)
const images = [
  ...rawImages
    .filter((image) => !hiddenFilenames.has(image.filename))
    .map((image) => ({
      src: image.src,
      width: image.width,
      height: image.height,
      alt: image.alt,
      filename: image.filename,
      caption: image.caption,
      featured: image.featured,
    })),
  ...adminUploadedImages,
]
const guestImages = dynamicComingSoon
  ? []
  : [
      ...publishedGuests.map(publicGuestPhoto),
      ...uploadedImages.filter((image) => image.source === 'guest'),
    ]
const allImages = [...images, ...guestImages]
const totalPhotoCount = allImages.length

const galleryId = `gallery-${eventSlug}`
const galleryUrl = new URL(`/galleries/${eventSlug}/`, Astro.site).toString()
const portfolioUrl = project ? `/portfolio/${project.id}/` : '/galleries/'
const galleryTitle = data?.title ?? dynamicEvent?.title ?? 'Event Gallery'
const galleryCategory =
  data?.category ?? dynamicEvent?.category ?? 'Event Photography'
const galleryImageAlt = data?.imageAlt ?? `${galleryTitle} event gallery`
const summary =
  data?.galleryDescription ?? data?.summary ?? dynamicEvent?.summary ?? ''
const title = `${galleryTitle} - Event Gallery`
const ogImage =
  allImages[0]?.src ??
  (dynamicEvent ? publicEventFlyer(dynamicEvent)?.src : undefined) ??
  (data
    ? typeof data.featuredImage === 'string'
      ? data.featuredImage
      : data.featuredImage.src
    : '/og.jpg')
const eventDate =
  data?.eventDate ??
  (dynamicEvent?.event_date
    ? new Date(`${dynamicEvent.event_date}T00:00:00Z`)
    : undefined)
const tipUrl = siteConfig.socialLinks.find((link) => link.id === 'kofi')?.url
const faceManifest = faceManifests[eventSlug]
const flyer =
  data &&
  typeof data.featuredImage === 'object' &&
  data.featuredImage !== null &&
  !('filename' in data.featuredImage)
    ? (data.featuredImage as ImageMetadata)
    : dynamicEvent
      ? publicEventFlyer(dynamicEvent)
      : undefined
const remoteFeaturedImage =
  data &&
  typeof data.featuredImage === 'object' &&
  data.featuredImage !== null &&
  'filename' in data.featuredImage &&
  !hiddenFilenames.has(data.featuredImage.filename)
    ? data.featuredImage
    : undefined
const galleryHeroImage = remoteFeaturedImage ?? images[0]

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(date)
---

<BaseLayout
  title={title}
  description={summary}
  canonicalUrl={galleryUrl}
  ogImage={ogImage}
  ogImageAlt={galleryImageAlt}
  ogType="article"
  robots="index,follow,max-image-preview:large"
  activeNav="galleries"
>
  <main
    id="main-content"
    class="mx-auto w-full max-w-screen-xl scroll-mt-20 px-4 py-6 sm:px-6 sm:py-8 lg:px-8"
  >
    <Breadcrumb>
      <BreadcrumbList>
        <BreadcrumbItem>
          <BreadcrumbLink
            href="/"
            className="focus-visible:ring-ring rounded-sm focus-visible:ring-2 focus-visible:outline-none"
          >
            Home
          </BreadcrumbLink>
        </BreadcrumbItem>
        <BreadcrumbSeparator />
        <BreadcrumbItem>
          <BreadcrumbLink
            href="/galleries"
            className="focus-visible:ring-ring rounded-sm focus-visible:ring-2 focus-visible:outline-none"
          >
            Galleries
          </BreadcrumbLink>
        </BreadcrumbItem>
        <BreadcrumbSeparator />
        <BreadcrumbItem>
          <BreadcrumbPage>{galleryTitle}</BreadcrumbPage>
        </BreadcrumbItem>
      </BreadcrumbList>
    </Breadcrumb>

    <header class="mx-auto max-w-4xl pt-6 sm:pt-8">
      <div class="flex flex-wrap items-center gap-2">
        {
          eventDate && (
            <Badge variant="secondary">{formatDate(eventDate)}</Badge>
          )
        }
        <Badge variant="outline">{galleryCategory}</Badge>
        {
          totalPhotoCount > 0 ? (
            <span class="text-muted-foreground text-xs font-semibold">
              {totalPhotoCount}
              {totalPhotoCount === 1 ? ' photograph' : ' photographs'}
            </span>
          ) : (
            <Badge variant="outline">Coming soon</Badge>
          )
        }
      </div>
      <h1
        class="font-heading mt-3 text-3xl leading-none font-extrabold tracking-tight sm:text-4xl lg:text-5xl"
      >
        {galleryTitle}
      </h1>
      <p class="text-muted-foreground mt-4 max-w-2xl text-base leading-7">
        {summary}
      </p>
      {
        (totalPhotoCount > 0 || gallerySettings?.uploads_enabled) && (
          <div class="mt-6 flex flex-wrap items-center gap-3">
            {totalPhotoCount > 0 && (
              <EventLightbox
                client:load
                galleryId={galleryId}
                heading={galleryTitle}
                projectSlug={eventSlug}
                projectTitle={galleryTitle}
                downloadAllUrl={data?.downloadAllUrl}
                tipUrl={tipUrl}
                images={allImages.map(({ src, filename, alt }) => ({
                  src,
                  filename,
                  alt,
                }))}
              >
                {allImages.map((image, index) => (
                  <figure
                    class="m-0 flex h-full w-full flex-col items-center justify-center"
                    data-gallery-slide={index}
                    hidden={index !== 0}
                  >
                    <Image
                      src={image.src}
                      alt={image.alt}
                      width={image.width}
                      height={image.height}
                      layout="constrained"
                      widths={[960, 1440, 1920, 2400]}
                      sizes="100vw"
                      loading="lazy"
                      decoding="async"
                      class="max-h-[calc(100dvh-9rem)] w-auto max-w-full object-contain"
                    />
                    <figcaption class="mt-3 max-w-3xl text-center text-sm text-white/75">
                      {'caption' in image && image.caption
                        ? image.caption
                        : image.filename}
                    </figcaption>
                  </figure>
                ))}
              </EventLightbox>
            )}
            {gallerySettings?.uploads_enabled ? (
              <Button variant="outline" size="lg" asChild>
                <a href={`/galleries/${eventSlug}/upload/`}>
                  <ImageUp data-icon="inline-start" aria-hidden="true" />
                  Share your photos
                </a>
              </Button>
            ) : null}
          </div>
        )
      }
    </header>

    {
      images.length > 0 && (
        <figure class="mx-auto mt-8 max-w-4xl overflow-hidden rounded-2xl">
          {galleryHeroImage ? (
            <Image
              src={galleryHeroImage.src}
              alt={galleryHeroImage.alt}
              width={galleryHeroImage.width}
              height={galleryHeroImage.height}
              layout="constrained"
              widths={[720, 1080, 1440, 1920]}
              sizes="(min-width: 1024px) 56rem, 100vw"
              quality={85}
              class="bg-muted block aspect-[3/2] size-full object-cover"
            />
          ) : (
            flyer && (
              <Image
                src={flyer as ImageMetadata}
                alt={galleryImageAlt}
                widths={[720, 1080, 1440, 1920]}
                sizes="(min-width: 1024px) 56rem, 100vw"
                quality={85}
                class="bg-muted block aspect-[3/2] size-full object-cover"
              />
            )
          )}
        </figure>
      )
    }

    {
      faceManifest && (
        <FaceFinder
          client:only="react"
          eventSlug={eventSlug}
          indexVersion={faceManifest.version}
          galleryId={galleryId}
        />
      )
    }

    {
      totalPhotoCount === 0 && flyer ? (
        <EventComingSoon
          flyer={flyer}
          flyerAlt={galleryImageAlt}
          date={eventDate ? formatDate(eventDate) : 'Date coming soon'}
          time={data?.eventTime ?? dynamicEvent?.event_time ?? undefined}
          venue={data?.eventVenue ?? dynamicEvent?.event_venue ?? undefined}
          upcomingVideo={data?.upcomingVideo}
        />
      ) : (
        <section
          id={galleryId}
          class="mt-10"
          aria-label={`${galleryTitle} photographs`}
        >
          {images.length > 0 && (
            <div
              class="columns-1 gap-1 sm:columns-2 lg:columns-3"
              data-gallery-grid
            >
              {images.map((image, index) => (
                <figure
                  class="relative mb-1 break-inside-avoid"
                  data-gallery-filename={image.filename}
                >
                  <Badge
                    variant="secondary"
                    data-face-rank
                    hidden
                    className="absolute top-2 left-2"
                  >
                    Match
                  </Badge>
                  <a
                    href={image.src}
                    data-gallery-open={index}
                    aria-label={`Open photograph ${index + 1}: ${image.alt}`}
                    class="group bg-muted focus-visible:ring-ring block overflow-hidden focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
                  >
                    <Image
                      src={image.src}
                      alt={image.alt}
                      width={image.width}
                      height={image.height}
                      layout="full-width"
                      widths={[480, 720, 960, 1280]}
                      sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                      loading="lazy"
                      decoding="async"
                      class="block h-auto w-full transition-opacity duration-300 ease-out group-hover:opacity-90"
                    />
                  </a>
                  <Button
                    type="button"
                    variant="secondary"
                    size="icon"
                    data-gallery-favorite
                    data-filename={image.filename}
                    data-selected="false"
                    aria-label={`Add photograph ${index + 1} to favorites`}
                    aria-pressed="false"
                    className="absolute top-2 right-2 shadow-md data-[selected=true]:bg-primary data-[selected=true]:text-primary-foreground data-[selected=true]:[&_svg]:fill-current"
                  >
                    <Heart aria-hidden="true" />
                  </Button>
                </figure>
              ))}
            </div>
          )}
          {guestImages.length > 0 && (
            <section class="mt-14" aria-labelledby="guest-photos-heading">
              <div class="mb-6 max-w-2xl">
                <Badge variant="secondary">Community gallery</Badge>
                <h2
                  id="guest-photos-heading"
                  class="font-heading mt-3 text-2xl font-extrabold tracking-tight sm:text-3xl"
                >
                  Photos shared by guests
                </h2>
                <p class="text-muted-foreground mt-2 leading-7">
                  Moments captured and submitted by people who attended the
                  event.
                </p>
              </div>
              <div class="columns-1 gap-1 sm:columns-2 lg:columns-3">
                {guestImages.map((image, index) => {
                  const photoIndex = images.length + index
                  return (
                    <figure
                      class="relative mb-1 break-inside-avoid"
                      data-gallery-filename={image.filename}
                    >
                      <a
                        href={image.src}
                        data-gallery-open={photoIndex}
                        aria-label={`Open guest photograph ${index + 1}: ${image.alt}`}
                        class="group bg-muted focus-visible:ring-ring block overflow-hidden focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
                      >
                        <Image
                          src={image.src}
                          alt={image.alt}
                          width={image.width}
                          height={image.height}
                          layout="full-width"
                          widths={[480, 720, 960, 1280]}
                          sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                          loading="lazy"
                          decoding="async"
                          class="block h-auto w-full transition-opacity duration-300 ease-out group-hover:opacity-90"
                        />
                      </a>
                      <Button
                        type="button"
                        variant="secondary"
                        size="icon"
                        data-gallery-favorite
                        data-filename={image.filename}
                        data-selected="false"
                        aria-label={`Add guest photograph ${index + 1} to favorites`}
                        aria-pressed="false"
                        className="absolute top-2 right-2 shadow-md data-[selected=true]:bg-primary data-[selected=true]:text-primary-foreground data-[selected=true]:[&_svg]:fill-current"
                      >
                        <Heart aria-hidden="true" />
                      </Button>
                    </figure>
                  )
                })}
              </div>
            </section>
          )}
        </section>
      )
    }

    <footer class="border-border mt-12 border-t pt-6">
      <a
        href={portfolioUrl}
        class="text-foreground hover:text-primary focus-visible:ring-ring inline-flex items-center gap-2 rounded-sm text-sm font-bold underline decoration-dotted underline-offset-4 focus-visible:ring-2 focus-visible:outline-none"
      >
        About this event
        <ArrowRight className="size-4" aria-hidden="true" />
      </a>
    </footer>
  </main>
</BaseLayout>

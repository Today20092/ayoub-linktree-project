---
import '../../../styles.css'

import { Image } from 'astro:assets'
import { ArrowRight, Download } from 'lucide-react'
import { getCollection, type CollectionEntry } from 'astro:content'

import EventLightbox from '../../../components/EventLightbox'
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from '../../../components/ui/breadcrumb'
import { Badge } from '../../../components/ui/badge'
import { Button, buttonVariants } from '../../../components/ui/button'
import { eventGalleries } from '../../../data/event-galleries'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import {
  computeJustifiedRows,
  type RowImage,
} from '../../../lib/justified-rows'
import { cn } from '../../../lib/utils'

type RemoteGalleryImage = {
  src: string
  width: number
  height: number
  alt: string
  filename: string
  caption?: string
  featured?: boolean
}

type Props = {
  project: CollectionEntry<'portfolio'>
}

export async function getStaticPaths() {
  const projects = (await getCollection('portfolio')).filter(
    (entry) => entry.data.eventGallery,
  )

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }))
}

const { project } = Astro.props as Props
const data = project.data

const inlineImages = data.gallery.filter(
  (
    image,
  ): image is Extract<(typeof data.gallery)[number], { filename: string }> =>
    'filename' in image,
)
const fallbackImages = eventGalleries[project.id] ?? []
const rawImages: RemoteGalleryImage[] =
  inlineImages.length > 0
    ? (inlineImages as unknown as RemoteGalleryImage[])
    : fallbackImages

const images: RowImage[] = rawImages.map((image) => ({
  src: image.src,
  width: image.width,
  height: image.height,
  alt: image.alt,
  filename: image.filename,
  caption: image.caption,
  featured: image.featured,
}))

const rows = computeJustifiedRows(images)

const galleryId = `gallery-${project.id}`
const galleryUrl = new URL(`/galleries/${project.id}/`, Astro.site).toString()
const portfolioUrl = `/portfolio/${project.id}/`
const summary = data.galleryDescription ?? data.summary
const title = `${data.title} — Event Gallery`
const ogImage = images[0]?.src ?? data.featuredImage
const eventDate = data.eventDate

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(date)

let runningIndex = 0
---

<BaseLayout
  title={title}
  description={summary}
  canonicalUrl={galleryUrl}
  ogImage={ogImage}
  ogImageAlt={data.imageAlt}
  ogType="article"
  robots="index,follow,max-image-preview:large"
  activeNav="galleries"
>
  <main
    id="main-content"
    class="mx-auto w-full max-w-screen-xl scroll-mt-20 px-4 py-6 sm:px-6 sm:py-8 lg:px-8"
  >
    <Breadcrumb>
      <BreadcrumbList>
        <BreadcrumbItem>
          <BreadcrumbLink
            href="/"
            className="focus-visible:ring-ring rounded-sm focus-visible:ring-2 focus-visible:outline-none"
          >
            Home
          </BreadcrumbLink>
        </BreadcrumbItem>
        <BreadcrumbSeparator />
        <BreadcrumbItem>
          <BreadcrumbLink
            href="/galleries"
            className="focus-visible:ring-ring rounded-sm focus-visible:ring-2 focus-visible:outline-none"
          >
            Galleries
          </BreadcrumbLink>
        </BreadcrumbItem>
        <BreadcrumbSeparator />
        <BreadcrumbItem>
          <BreadcrumbPage>{data.title}</BreadcrumbPage>
        </BreadcrumbItem>
      </BreadcrumbList>
    </Breadcrumb>

    <header class="mx-auto max-w-4xl pt-6 sm:pt-8">
      <div class="flex flex-wrap items-center gap-2">
        {
          eventDate && (
            <Badge variant="secondary">{formatDate(eventDate)}</Badge>
          )
        }
        <Badge variant="outline">{data.category}</Badge>
        <span class="text-muted-foreground text-xs font-semibold">
          {images.length}
          {images.length === 1 ? ' photograph' : ' photographs'}
        </span>
      </div>
      <h1
        class="font-heading mt-3 text-3xl leading-none font-extrabold tracking-tight sm:text-4xl lg:text-5xl"
      >
        {data.title}
      </h1>
      <p class="text-muted-foreground mt-4 max-w-2xl text-base leading-7">
        {summary}
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <EventLightbox
          client:load
          galleryId={galleryId}
          heading={data.title}
          projectSlug={project.id}
          projectTitle={data.title}
          images={images.map(({ src, filename, alt }) => ({
            src,
            filename,
            alt,
          }))}
        >
          {
            images.map((image, index) => (
              <figure
                class="m-0 flex h-full w-full flex-col items-center justify-center"
                data-gallery-slide={index}
                hidden={index !== 0}
              >
                <Image
                  src={image.src}
                  alt={image.alt}
                  width={image.width}
                  height={image.height}
                  layout="constrained"
                  widths={[960, 1440, 1920, 2400]}
                  sizes="100vw"
                  loading="lazy"
                  decoding="async"
                  class="max-h-[calc(100dvh-9rem)] w-auto max-w-full object-contain"
                />
                {(image.caption || image.filename) && (
                  <figcaption class="mt-3 max-w-3xl text-center text-sm text-white/75">
                    {image.caption ?? image.filename}
                  </figcaption>
                )}
              </figure>
            ))
          }
        </EventLightbox>
        {
          data.downloadAllUrl && (
            <a
              href={data.downloadAllUrl}
              download
              class={cn(buttonVariants({ variant: 'outline', size: 'lg' }))}
            >
              <Download data-icon="inline-start" aria-hidden="true" />
              Download all
            </a>
          )
        }
      </div>
    </header>

    <section
      id={galleryId}
      class="mt-10"
      style="--gallery-row-height: clamp(140px, 6rem + 14vw, 260px);"
      aria-label={`${data.title} photographs`}
    >
      <div class="flex flex-col gap-2">
        {
          rows.map((row) => (
            <div
              class:list={[
                'gallery-row flex w-full gap-2',
                row.isLast ? 'flex-wrap' : '',
              ]}
              style={
                !row.isLast ? `aspect-ratio: ${row.aspectRatio};` : undefined
              }
            >
              {row.images.map((image) => {
                const index = runningIndex++
                return (
                  <a
                    href={image.src}
                    data-gallery-open={index}
                    aria-label={`Open photograph ${index + 1}: ${image.alt}`}
                    class="group bg-muted focus-visible:ring-ring relative block overflow-hidden rounded-sm focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
                    style={
                      row.isLast
                        ? 'flex: none; height: var(--gallery-row-height);'
                        : `flex: ${image.width / image.height} 1 0%; min-width: 0;`
                    }
                  >
                    <Image
                      src={image.src}
                      alt={image.alt}
                      width={image.width}
                      height={image.height}
                      layout="constrained"
                      widths={[480, 720, 960, 1280]}
                      sizes="(min-width: 1280px) 33vw, (min-width: 640px) 50vw, 100vw"
                      loading="lazy"
                      decoding="async"
                      class="size-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.02]"
                    />
                  </a>
                )
              })}
            </div>
          ))
        }
      </div>
    </section>

    <footer class="border-border mt-12 border-t pt-6">
      <a
        href={portfolioUrl}
        class="text-foreground hover:text-primary focus-visible:ring-ring inline-flex items-center gap-2 rounded-sm text-sm font-bold underline decoration-dotted underline-offset-4 focus-visible:ring-2 focus-visible:outline-none"
      >
        About this event
        <ArrowRight className="size-4" aria-hidden="true" />
      </a>
    </footer>
  </main>
</BaseLayout>

<style is:global>
  @media (max-width: 639px) {
    .gallery-row {
      aspect-ratio: auto !important;
      flex-wrap: wrap;
    }
    .gallery-row > a {
      flex: 1 1 calc(50% - 0.25rem) !important;
      height: 140px !important;
      min-width: 0 !important;
    }
  }
</style>

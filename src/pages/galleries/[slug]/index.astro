---
import '../../../styles.css'

import { Image } from 'astro:assets'
import { ArrowRight, Heart } from 'lucide-react'
import { getCollection, type CollectionEntry } from 'astro:content'

import EventLightbox from '../../../components/EventLightbox'
import FaceFinder from '../../../components/FaceFinder'
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from '../../../components/ui/breadcrumb'
import { Badge } from '../../../components/ui/badge'
import { Button } from '../../../components/ui/button'
import { eventGalleries } from '../../../data/event-galleries'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { faceManifests } from '../../../lib/face-manifests'
import { siteConfig } from '../../../lib/site-config'

type RemoteGalleryImage = {
  src: string
  width: number
  height: number
  alt: string
  filename: string
  caption?: string
  featured?: boolean
}

type Props = {
  project: CollectionEntry<'portfolio'>
}

export async function getStaticPaths() {
  const projects = (await getCollection('portfolio')).filter(
    (entry) => entry.data.eventGallery,
  )

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }))
}

const { project } = Astro.props as Props
const data = project.data

const inlineImages = data.gallery.filter(
  (
    image,
  ): image is Extract<(typeof data.gallery)[number], { filename: string }> =>
    'filename' in image,
)
const fallbackImages = eventGalleries[project.id] ?? []
const rawImages: RemoteGalleryImage[] =
  inlineImages.length > 0
    ? (inlineImages as unknown as RemoteGalleryImage[])
    : fallbackImages

const images = rawImages.map((image) => ({
  src: image.src,
  width: image.width,
  height: image.height,
  alt: image.alt,
  filename: image.filename,
  caption: image.caption,
  featured: image.featured,
}))

const galleryId = `gallery-${project.id}`
const galleryUrl = new URL(`/galleries/${project.id}/`, Astro.site).toString()
const portfolioUrl = `/portfolio/${project.id}/`
const summary = data.galleryDescription ?? data.summary
const title = `${data.title} — Event Gallery`
const ogImage =
  images[0]?.src ??
  (typeof data.featuredImage === 'string'
    ? data.featuredImage
    : data.featuredImage.src)
const eventDate = data.eventDate
const tipUrl = siteConfig.socialLinks.find((link) => link.id === 'kofi')?.url
const faceManifest = data.faceSearch ? faceManifests[project.id] : undefined

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(date)
---

<BaseLayout
  title={title}
  description={summary}
  canonicalUrl={galleryUrl}
  ogImage={ogImage}
  ogImageAlt={data.imageAlt}
  ogType="article"
  robots="index,follow,max-image-preview:large"
  activeNav="galleries"
>
  <main
    id="main-content"
    class="mx-auto w-full max-w-screen-xl scroll-mt-20 px-4 py-6 sm:px-6 sm:py-8 lg:px-8"
  >
    <Breadcrumb>
      <BreadcrumbList>
        <BreadcrumbItem>
          <BreadcrumbLink
            href="/"
            className="focus-visible:ring-ring rounded-sm focus-visible:ring-2 focus-visible:outline-none"
          >
            Home
          </BreadcrumbLink>
        </BreadcrumbItem>
        <BreadcrumbSeparator />
        <BreadcrumbItem>
          <BreadcrumbLink
            href="/galleries"
            className="focus-visible:ring-ring rounded-sm focus-visible:ring-2 focus-visible:outline-none"
          >
            Galleries
          </BreadcrumbLink>
        </BreadcrumbItem>
        <BreadcrumbSeparator />
        <BreadcrumbItem>
          <BreadcrumbPage>{data.title}</BreadcrumbPage>
        </BreadcrumbItem>
      </BreadcrumbList>
    </Breadcrumb>

    <header class="mx-auto max-w-4xl pt-6 sm:pt-8">
      <div class="flex flex-wrap items-center gap-2">
        {
          eventDate && (
            <Badge variant="secondary">{formatDate(eventDate)}</Badge>
          )
        }
        <Badge variant="outline">{data.category}</Badge>
        <span class="text-muted-foreground text-xs font-semibold">
          {images.length}
          {images.length === 1 ? ' photograph' : ' photographs'}
        </span>
      </div>
      <h1
        class="font-heading mt-3 text-3xl leading-none font-extrabold tracking-tight sm:text-4xl lg:text-5xl"
      >
        {data.title}
      </h1>
      <p class="text-muted-foreground mt-4 max-w-2xl text-base leading-7">
        {summary}
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <EventLightbox
          client:load
          galleryId={galleryId}
          heading={data.title}
          projectSlug={project.id}
          projectTitle={data.title}
          downloadAllUrl={data.downloadAllUrl}
          tipUrl={tipUrl}
          images={images.map(({ src, filename, alt }) => ({
            src,
            filename,
            alt,
          }))}
        >
          {
            images.map((image, index) => (
              <figure
                class="m-0 flex h-full w-full flex-col items-center justify-center"
                data-gallery-slide={index}
                hidden={index !== 0}
              >
                <Image
                  src={image.src}
                  alt={image.alt}
                  width={image.width}
                  height={image.height}
                  layout="constrained"
                  widths={[960, 1440, 1920, 2400]}
                  sizes="100vw"
                  loading="lazy"
                  decoding="async"
                  class="max-h-[calc(100dvh-9rem)] w-auto max-w-full object-contain"
                />
                {(image.caption || image.filename) && (
                  <figcaption class="mt-3 max-w-3xl text-center text-sm text-white/75">
                    {image.caption ?? image.filename}
                  </figcaption>
                )}
              </figure>
            ))
          }
        </EventLightbox>
      </div>
    </header>

    {
      faceManifest && (
        <FaceFinder
          client:load
          eventSlug={project.id}
          indexVersion={faceManifest.version}
          galleryId={galleryId}
        />
      )
    }

    <section
      id={galleryId}
      class="mt-10"
      aria-label={`${data.title} photographs`}
    >
      <div class="columns-1 gap-1 sm:columns-2 lg:columns-3" data-gallery-grid>
        {
          images.map((image, index) => (
            <figure
              class="relative mb-1 break-inside-avoid"
              data-gallery-filename={image.filename}
            >
              <Badge
                variant="secondary"
                data-face-rank
                hidden
                className="absolute top-2 left-2"
              >
                Match
              </Badge>
              <a
                href={image.src}
                data-gallery-open={index}
                aria-label={`Open photograph ${index + 1}: ${image.alt}`}
                class="group bg-muted focus-visible:ring-ring block overflow-hidden focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none"
              >
                <Image
                  src={image.src}
                  alt={image.alt}
                  width={image.width}
                  height={image.height}
                  layout="full-width"
                  widths={[480, 720, 960, 1280]}
                  sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                  loading="lazy"
                  decoding="async"
                  class="block h-auto w-full transition-opacity duration-300 ease-out group-hover:opacity-90"
                />
              </a>
              <Button
                type="button"
                variant="secondary"
                size="icon"
                data-gallery-favorite
                data-filename={image.filename}
                data-selected="false"
                aria-label={`Add photograph ${index + 1} to favorites`}
                aria-pressed="false"
                className="absolute top-2 right-2 shadow-md data-[selected=true]:bg-primary data-[selected=true]:text-primary-foreground data-[selected=true]:[&_svg]:fill-current"
              >
                <Heart aria-hidden="true" />
              </Button>
            </figure>
          ))
        }
      </div>
    </section>

    <footer class="border-border mt-12 border-t pt-6">
      <a
        href={portfolioUrl}
        class="text-foreground hover:text-primary focus-visible:ring-ring inline-flex items-center gap-2 rounded-sm text-sm font-bold underline decoration-dotted underline-offset-4 focus-visible:ring-2 focus-visible:outline-none"
      >
        About this event
        <ArrowRight className="size-4" aria-hidden="true" />
      </a>
    </footer>
  </main>
</BaseLayout>

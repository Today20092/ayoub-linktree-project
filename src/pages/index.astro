---
import '../styles.css'

import type { ImageMetadata } from 'astro'
import { getCollection } from 'astro:content'

import PortfolioIndex from '../components/PortfolioIndex.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { sortPortfolioProjects } from '../lib/portfolio-order'
import { getBaseUrl, resolveSiteAsset, siteConfig } from '../lib/site-config'

const {
  pageTitle,
  pageDescription,
  shareTitle,
  shareDescription,
  shareText,
  siteName,
  profileName,
  twitterHandle,
  profileImage,
  ogImage,
  ogImageAlt,
  ogImageWidth,
  ogImageHeight,
  ogImageType,
} = siteConfig.site
const { socialLinks, actionLinks, youtubeChannels } = siteConfig
const baseUrl = getBaseUrl(import.meta.env.BASE_URL)
const currentYear = new Date().getFullYear()
const canonicalUrl = new URL(baseUrl, Astro.site).toString()
const sitemapUrl = new URL(`${baseUrl}sitemap-index.xml`, Astro.site).toString()
const ogImageUrl = new URL(
  resolveSiteAsset(baseUrl, ogImage),
  Astro.site,
).toString()
const profileImageUrl = new URL(
  resolveSiteAsset(baseUrl, profileImage),
  Astro.site,
).toString()
const primaryLinks = actionLinks.filter((link) => link.group === 'primary')
const supportLinks = actionLinks.filter((link) => link.group === 'support')
const sameAsUrls = socialLinks.map((link) => link.url)
const portfolioProjects = (await getCollection('portfolio'))
  .sort(sortPortfolioProjects)
  .map((entry) => {
    const thumbnailAsset = entry.data.thumbnail ?? entry.data.featuredImage
    const thumbnail =
      typeof thumbnailAsset === 'object' &&
      thumbnailAsset !== null &&
      'filename' in thumbnailAsset
        ? thumbnailAsset.src
        : (thumbnailAsset as ImageMetadata | string)
    const thumbnailAlt =
      typeof thumbnailAsset === 'object' &&
      thumbnailAsset !== null &&
      'alt' in thumbnailAsset
        ? thumbnailAsset.alt
        : entry.data.imageAlt
    const thumbnailWidth =
      typeof thumbnailAsset === 'object' &&
      thumbnailAsset !== null &&
      'width' in thumbnailAsset
        ? thumbnailAsset.width
        : entry.data.imageWidth
    const thumbnailHeight =
      typeof thumbnailAsset === 'object' &&
      thumbnailAsset !== null &&
      'height' in thumbnailAsset
        ? thumbnailAsset.height
        : entry.data.imageHeight

    return {
      slug: entry.id,
      title: entry.data.title,
      category: entry.data.category,
      thumbnail,
      imageAlt: thumbnailAlt,
      imageWidth: thumbnailWidth,
      imageHeight: thumbnailHeight,
    }
  })

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${canonicalUrl}#profile-page`,
  url: canonicalUrl,
  name: pageTitle,
  description: pageDescription,
  image: ogImageUrl,
  inLanguage: 'en',
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${canonicalUrl}#website`,
    url: canonicalUrl,
    name: siteName,
  },
  mainEntity: {
    '@type': 'Person',
    '@id': `${canonicalUrl}#person`,
    name: profileName,
    alternateName: pageTitle,
    description: pageDescription,
    image: profileImageUrl,
    url: canonicalUrl,
    sameAs: sameAsUrls,
  },
  significantLink: sameAsUrls,
}
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  ogTitle={shareTitle}
  ogDescription={shareDescription}
  ogImage={ogImageUrl}
  ogImageAlt={ogImageAlt}
  ogImageWidth={ogImageWidth}
  ogImageHeight={ogImageHeight}
  ogImageType={ogImageType}
  ogType="website"
  twitterHandle={twitterHandle}
  sitemapUrl={sitemapUrl}
  structuredData={structuredData}
  activeNav="home"
>
  <PortfolioIndex
    pageDescription={pageDescription}
    shareTitle={shareTitle}
    shareText={shareText}
    shareUrl={canonicalUrl}
    currentYear={currentYear}
    primaryLinks={primaryLinks}
    socialLinks={socialLinks}
    supportLinks={supportLinks}
    channels={youtubeChannels}
    projects={portfolioProjects}
  />
</BaseLayout>

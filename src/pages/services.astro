---
import '../styles.css'

import type { CollectionEntry } from 'astro:content'
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'

import { buttonVariants } from '@/components/ui/button'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getBaseUrl, resolveSiteAsset, siteConfig } from '../lib/site-config'

type PortfolioEntry = CollectionEntry<'portfolio'>

type ProofProject = {
  slug: string
  title: string
  category: string
  summary: string
  thumbnail: ImageMetadata | string
  imageAlt: string
  imageWidth: number
  imageHeight: number
}

type Service = {
  title: string
  summary: string
  bestFor: string
  includes: string[]
  startingAt: string
  projectIds: string[]
}

type ServiceWithProjects = Service & {
  projects: ProofProject[]
}

const servicePageTitle = 'Photography and Video Services | Ayoub Abedrabbo'
const servicePageDescription =
  'Audio visual setup, event recording, photography, video production, and media planning services in Tampa for mosques, nonprofits, schools, events, and community organizations.'

const { siteName, profileName, twitterHandle, ogImage, ogImageAlt } =
  siteConfig.site
const baseUrl = getBaseUrl(import.meta.env.BASE_URL)
const canonicalUrl = new URL(`${baseUrl}services`, Astro.site).toString()
const sitemapUrl = new URL(`${baseUrl}sitemap-index.xml`, Astro.site).toString()
const ogImageUrl = new URL(
  resolveSiteAsset(baseUrl, ogImage),
  Astro.site,
).toString()

const portfolioEntries = await getCollection('portfolio')
const entriesById = new Map(portfolioEntries.map((entry) => [entry.id, entry]))

const toProofProject = (entry: PortfolioEntry): ProofProject => {
  const thumbnailAsset = entry.data.thumbnail ?? entry.data.featuredImage
  const thumbnail =
    typeof thumbnailAsset === 'object' &&
    thumbnailAsset !== null &&
    'filename' in thumbnailAsset
      ? thumbnailAsset.src
      : (thumbnailAsset as ImageMetadata | string)
  const thumbnailAlt =
    typeof thumbnailAsset === 'object' &&
    thumbnailAsset !== null &&
    'alt' in thumbnailAsset
      ? thumbnailAsset.alt
      : entry.data.imageAlt
  const thumbnailWidth =
    typeof thumbnailAsset === 'object' &&
    thumbnailAsset !== null &&
    'width' in thumbnailAsset
      ? thumbnailAsset.width
      : entry.data.imageWidth
  const thumbnailHeight =
    typeof thumbnailAsset === 'object' &&
    thumbnailAsset !== null &&
    'height' in thumbnailAsset
      ? thumbnailAsset.height
      : entry.data.imageHeight

  return {
    slug: entry.id,
    title: entry.data.title,
    category: entry.data.category,
    summary: entry.data.summary,
    thumbnail,
    imageAlt: thumbnailAlt,
    imageWidth: thumbnailWidth,
    imageHeight: thumbnailHeight,
  }
}

const serviceDefinitions: Service[] = [
  {
    title: 'AV setup and recording',
    summary:
      'Clear speech audio for lectures, khutbahs, fundraisers, and community events, with wireless microphones and simple full-event recording available.',
    bestFor:
      'Mosques, nonprofits, schools, lectures, nikahs, fundraisers, and 25-150 person community programs.',
    includes: [
      'Speaker and microphone setup',
      'Mixer, EQ, and feedback control',
      'Optional full-event recording',
    ],
    startingAt: '$500 with recording',
    projectIds: [
      'temple-terrace-community-open-house',
      'muslim-business-chamber-2026',
      'bayaan-academy',
    ],
  },
  {
    title: 'Photography',
    summary:
      'Event coverage, portraits, headshots, and galleries for people and organizations that need clean, useful images.',
    bestFor:
      'Workshops, weddings, community events, schools, professional teams, and local leaders.',
    includes: [
      'Event photography',
      'Portraits and headshots',
      'Client galleries and downloads',
    ],
    startingAt: '$300',
    projectIds: [
      'muslim-business-chamber-2026',
      'portraits',
      'sanad-silwadi-wedding',
    ],
  },
  {
    title: 'Video production',
    summary:
      'Business videos, event films, school stories, and social-ready pieces shaped around the message first.',
    bestFor:
      'Businesses, schools, nonprofits, fundraisers, and people explaining what they do.',
    includes: [
      'Talking-head videos',
      'Event and documentary films',
      'Editing, color, and delivery',
    ],
    startingAt: '$600',
    projectIds: ['omar-erchid-law-firm', 'aya-academy', 'maan-academy'],
  },
  {
    title: 'Podcast and media production',
    summary:
      'Recording, audio, lighting, editing, and channel planning for recurring shows and media projects.',
    bestFor:
      'Podcasts, interviews, YouTube channels, expert conversations, and brand media.',
    includes: [
      'Podcast recording setup',
      'Audio and lighting support',
      'Publishing-ready edits',
    ],
    startingAt: '$500',
    projectIds: ['rizqmd-jd-podcast', 'konan-bbq-podcast', 'lavena-health'],
  },
]

const avPackages = [
  {
    name: 'AV setup',
    price: '$250-$350',
    detail:
      'Speaker placement, wireless mic setup, mixer setup, EQ, soundcheck, and handoff.',
  },
  {
    name: 'AV setup with operator',
    price: '$450-$650',
    detail:
      'Setup plus a live operator during the event, managed by Ayoub when the event needs active sound support.',
  },
  {
    name: 'AV setup with recording',
    price: '$500-$750',
    detail:
      'Clean event sound plus a simple full lecture or program recording delivered as a file.',
  },
]

const mediaAddOns = [
  'Fast photo gallery: $300-$700',
  'Guest upload and download gallery: $100-$250',
  'Edited recap or interview video: $600-$1,500',
  'YouTube upload prep: $100-$250',
]

const services: ServiceWithProjects[] = serviceDefinitions.map((service) => ({
  ...service,
  projects: service.projectIds
    .map((id) => entriesById.get(id))
    .filter((entry): entry is PortfolioEntry => Boolean(entry))
    .map(toProofProject),
}))

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonicalUrl}#services`,
  name: servicePageTitle,
  description: servicePageDescription,
  provider: {
    '@type': 'Person',
    name: profileName,
    url: new URL(baseUrl, Astro.site).toString(),
  },
  areaServed: {
    '@type': 'Place',
    name: 'Tampa Bay',
  },
  serviceType: services.map((service) => service.title),
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${new URL(baseUrl, Astro.site).toString()}#website`,
    url: new URL(baseUrl, Astro.site).toString(),
    name: siteName,
  },
}
---

<BaseLayout
  title={servicePageTitle}
  description={servicePageDescription}
  canonicalUrl={canonicalUrl}
  ogTitle={servicePageTitle}
  ogDescription={servicePageDescription}
  ogImage={ogImageUrl}
  ogImageAlt={ogImageAlt}
  ogType="website"
  twitterHandle={twitterHandle}
  sitemapUrl={sitemapUrl}
  structuredData={structuredData}
  activeNav="services"
>
  <main
    id="main-content"
    class="mx-auto w-full max-w-screen-xl px-4 sm:px-6 lg:px-8"
  >
    <section class="pt-10 pb-10 lg:pt-16 lg:pb-14" data-reveal="fade">
      <div
        class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-end"
      >
        <div>
          <p
            class="text-muted-foreground mb-4 text-xs font-semibold tracking-wider uppercase"
          >
            Services
          </p>
          <h1
            class="font-heading text-foreground max-w-3xl text-4xl leading-[1.02] font-extrabold tracking-tight text-balance sm:text-5xl lg:text-6xl"
          >
            Clear event sound, recording, and media coverage.
          </h1>
        </div>
        <div class="max-w-2xl lg:pb-1">
          <p class="text-muted-foreground text-base leading-7 sm:text-lg">
            I help Tampa mosques, nonprofits, schools, events, and community
            leaders set up clean speech audio, capture the full program, and
            produce the photos or videos that help people remember and share it.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/#contact" class={buttonVariants({ size: 'lg' })}>
              Contact
            </a>
            <a
              href="#proof"
              class={buttonVariants({ variant: 'outline', size: 'lg' })}
            >
              View work
            </a>
          </div>
        </div>
      </div>

      <div
        class="border-border mt-10 grid overflow-hidden rounded-sm border md:grid-cols-2 lg:grid-cols-4"
        data-reveal="up"
        style="--reveal-delay: 140ms"
      >
        {
          services.map((service, index) => (
            <a
              href={`#${service.title.toLowerCase().replaceAll(' ', '-')}`}
              class="group border-border bg-card text-card-foreground hover:bg-accent hover:text-accent-foreground focus-visible:ring-ring block border-b p-5 no-underline transition-[background-color,color,transform] last:border-b-0 focus-visible:ring-2 focus-visible:outline-none active:scale-[0.99] lg:border-r lg:border-b-0 lg:last:border-r-0"
              data-reveal="up"
              style={`--reveal-delay: ${index * 70}ms`}
            >
              <h2 class="text-xl leading-tight font-extrabold">
                {service.title}
              </h2>
              <p class="text-muted-foreground group-hover:text-accent-foreground/80 mt-3 text-sm leading-6">
                {service.summary}
              </p>
              <p class="text-foreground group-hover:text-accent-foreground mt-4 text-sm font-extrabold">
                From {service.startingAt}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <section
      class="border-border scroll-mt-20 border-t py-10 lg:py-14"
      data-reveal="up"
      id="event-sound"
    >
      <div class="grid gap-8 lg:grid-cols-[minmax(0,0.78fr)_minmax(0,1.22fr)]">
        <div>
          <h2
            class="font-heading text-3xl font-extrabold tracking-tight sm:text-4xl"
          >
            Event sound setup for speech-first programs.
          </h2>
          <p class="text-muted-foreground mt-4 text-base leading-7">
            The main offer is simple: clear wireless audio, proper speaker
            placement, a mixer that is actually dialed in, and no feedback or
            harsh noise during the program.
          </p>
        </div>

        <div class="grid gap-4">
          {
            avPackages.map((item, index) => (
              <div
                class="border-border grid gap-3 rounded-sm border p-5 sm:grid-cols-[9rem_minmax(0,1fr)]"
                data-reveal="up"
                style={`--reveal-delay: ${index * 70}ms`}
              >
                <div>
                  <h3 class="text-base font-extrabold">{item.name}</h3>
                  <p class="text-primary mt-1 text-lg font-extrabold">
                    {item.price}
                  </p>
                </div>
                <p class="text-muted-foreground text-sm leading-6">
                  {item.detail}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
        <div class="bg-muted/45 rounded-sm p-5">
          <h3 class="text-lg font-extrabold">Media add-ons</h3>
          <ul class="text-muted-foreground mt-4 grid gap-2 text-sm leading-6">
            {mediaAddOns.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="bg-muted/45 rounded-sm p-5">
          <h3 class="text-lg font-extrabold">Launch setup</h3>
          <p class="text-muted-foreground mt-4 text-sm leading-6">
            Early bookings may use trusted borrowed gear while the owned kit is
            being built. The service price covers planning, setup, tuning, and
            delivery. Equipment is matched to the room and event needs.
          </p>
        </div>
      </div>
    </section>

    <section class="border-border border-t py-10 lg:py-14" data-reveal="up">
      <div class="grid gap-6 md:grid-cols-[minmax(0,0.7fr)_minmax(0,1.3fr)]">
        <h2
          class="font-heading text-2xl font-extrabold tracking-tight sm:text-3xl"
        >
          Event planning is part of the service.
        </h2>
        <p class="text-muted-foreground max-w-3xl text-base leading-7">
          Before the event, I work to understand the room, audience size, mic
          count, program flow, recording needs, and media goals. That planning
          shapes the sound setup, the capture plan, and what gets delivered
          after the event.
        </p>
      </div>
    </section>

    <section
      id="proof"
      class="border-border scroll-mt-20 border-t py-10 lg:py-14"
      data-reveal="fade"
    >
      <div class="max-w-2xl">
        <h2
          class="font-heading text-3xl font-extrabold tracking-tight sm:text-4xl"
        >
          Services with related work.
        </h2>
        <p class="text-muted-foreground mt-4 text-base leading-7">
          These examples show the media side of the work: community events,
          event galleries, school stories, business videos, and podcast
          production.
        </p>
      </div>

      <div class="mt-8 grid gap-6">
        {
          services.map((service, index) => {
            const featuredProject = service.projects[0]

            return (
              <article
                id={service.title.toLowerCase().replaceAll(' ', '-')}
                class="border-border scroll-mt-20 rounded-sm border p-4 sm:p-5"
                data-reveal="up"
                style={`--reveal-delay: ${Math.min(index, 3) * 70}ms`}
              >
                <div class="grid gap-5 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1.28fr)]">
                  <div>
                    <h3 class="font-heading text-2xl font-extrabold tracking-tight">
                      {service.title}
                    </h3>
                    <p class="text-muted-foreground mt-3 text-sm leading-6">
                      {service.bestFor}
                    </p>
                    <ul class="mt-5 grid gap-2 text-sm font-bold sm:grid-cols-3 lg:grid-cols-1">
                      {service.includes.map((item) => (
                        <li class="bg-muted/60 rounded-sm px-3 py-2">{item}</li>
                      ))}
                    </ul>
                  </div>

                  <div class="grid gap-4 md:grid-cols-[9rem_minmax(0,1fr)] md:items-start">
                    {featuredProject && (
                      <a
                        href={`/portfolio/${featuredProject.slug}/`}
                        class="group bg-muted focus-visible:ring-ring block overflow-hidden rounded-sm focus-visible:ring-2 focus-visible:outline-none"
                      >
                        {typeof featuredProject.thumbnail === 'string' ? (
                          <Image
                            src={featuredProject.thumbnail}
                            alt={featuredProject.imageAlt}
                            width={featuredProject.imageWidth}
                            height={featuredProject.imageHeight}
                            layout="constrained"
                            widths={[180, 260, 360]}
                            sizes="(min-width: 768px) 9rem, 100vw"
                            quality={75}
                            class="aspect-[4/3] w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
                          />
                        ) : (
                          <Image
                            src={featuredProject.thumbnail}
                            alt={featuredProject.imageAlt}
                            width={featuredProject.imageWidth}
                            height={featuredProject.imageHeight}
                            layout="constrained"
                            widths={[180, 260, 360]}
                            sizes="(min-width: 768px) 9rem, 100vw"
                            quality={75}
                            class="aspect-[4/3] w-full object-cover transition-opacity duration-200 group-hover:opacity-90"
                          />
                        )}
                      </a>
                    )}

                    <div class="grid gap-3">
                      {service.projects.map((project) => (
                        <a
                          href={`/portfolio/${project.slug}/`}
                          class="group border-border hover:bg-accent hover:text-accent-foreground focus-visible:ring-ring block rounded-sm border p-3 no-underline transition-[background-color,color,transform] focus-visible:ring-2 focus-visible:outline-none active:scale-[0.99]"
                        >
                          <strong class="text-foreground group-hover:text-accent-foreground block text-base leading-snug font-extrabold">
                            {project.title}
                          </strong>
                          <span class="text-muted-foreground group-hover:text-accent-foreground/80 mt-1 block text-sm leading-5">
                            {project.summary}
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              </article>
            )
          })
        }
      </div>
    </section>

    <section class="border-border border-t py-10 lg:py-14" data-reveal="up">
      <div class="max-w-2xl">
        <h2
          class="font-heading text-3xl font-extrabold tracking-tight sm:text-4xl"
        >
          How I run the job.
        </h2>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <div
          class="border-border rounded-sm border p-5"
          data-reveal="up"
          style="--reveal-delay: 0ms"
        >
          <h3 class="text-lg font-extrabold">Confirm the setup</h3>
          <p class="text-muted-foreground mt-3 text-sm leading-6">
            We confirm room size, speaker count, microphones, power, schedule,
            and recording needs before event day.
          </p>
        </div>
        <div
          class="border-border rounded-sm border p-5"
          data-reveal="up"
          style="--reveal-delay: 70ms"
        >
          <h3 class="text-lg font-extrabold">Tune the sound</h3>
          <p class="text-muted-foreground mt-3 text-sm leading-6">
            I place the speakers, set levels, EQ the microphones, control
            feedback, and make sure speech is clear.
          </p>
        </div>
        <div
          class="border-border rounded-sm border p-5"
          data-reveal="up"
          style="--reveal-delay: 140ms"
        >
          <h3 class="text-lg font-extrabold">Capture and deliver</h3>
          <p class="text-muted-foreground mt-3 text-sm leading-6">
            When recording or media coverage is included, I deliver the files,
            gallery, edit, or publishing support agreed before the event.
          </p>
        </div>
      </div>
    </section>

    <section class="border-border border-t py-10 lg:py-14" data-reveal="up">
      <div
        class="bg-muted/45 grid gap-6 rounded-sm p-6 sm:p-8 md:grid-cols-[minmax(0,1fr)_auto] md:items-center"
      >
        <div>
          <h2
            class="font-heading text-2xl font-extrabold tracking-tight sm:text-3xl"
          >
            Not sure what you need?
          </h2>
          <p class="text-muted-foreground mt-3 max-w-2xl text-base leading-7">
            Send the event date, venue, audience size, microphone count, and
            whether you need recording, photos, video, or a gallery. I can
            recommend the simplest setup that covers it.
          </p>
        </div>
        <a href="/#contact" class={buttonVariants({ size: 'lg' })}>Contact</a>
      </div>
    </section>
  </main>
</BaseLayout>

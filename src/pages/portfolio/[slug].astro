---
import '../../styles.css'

import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'
import { getCollection, render, type CollectionEntry } from 'astro:content'
import {
  ArrowLeft,
  ArrowRight,
  ArrowUpRight,
  Download,
  Play,
} from 'lucide-react'
import PortfolioLocation from '../../components/PortfolioLocation.astro'
import UpcomingVideo from '../../components/UpcomingVideo'
import YouTubeEmbed from '../../components/YouTubeEmbed.astro'
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from '../../components/ui/breadcrumb'
import { buttonVariants } from '../../components/ui/button'
import { Separator } from '../../components/ui/separator'
import { eventGalleries } from '../../data/event-galleries'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { sortPortfolioProjects } from '../../lib/portfolio-order'
import { cn } from '../../lib/utils'

export async function getStaticPaths() {
  const projects = (await getCollection('portfolio')).sort(
    sortPortfolioProjects,
  )

  return projects.map((project, index) => ({
    params: { slug: project.id },
    props: {
      project,
      previousProject:
        index > 0
          ? {
              id: projects[index - 1].id,
              title: projects[index - 1].data.title,
            }
          : undefined,
      nextProject:
        index < projects.length - 1
          ? {
              id: projects[index + 1].id,
              title: projects[index + 1].data.title,
            }
          : undefined,
    },
  }))
}

type Props = {
  project: CollectionEntry<'portfolio'>
  previousProject?: { id: string; title: string }
  nextProject?: { id: string; title: string }
}

const { project, previousProject, nextProject } = Astro.props as Props
const { Content } = await render(project)
const projectData = project.data
const heroImageAsset = projectData.heroImage ?? projectData.featuredImage
const heroImage =
  typeof heroImageAsset === 'object' &&
  heroImageAsset !== null &&
  'filename' in heroImageAsset
    ? heroImageAsset.src
    : (heroImageAsset as ImageMetadata | string)
const heroImageAlt =
  typeof heroImageAsset === 'object' &&
  heroImageAsset !== null &&
  'alt' in heroImageAsset
    ? heroImageAsset.alt
    : projectData.imageAlt
const heroImageWidth =
  typeof heroImageAsset === 'object' &&
  heroImageAsset !== null &&
  'width' in heroImageAsset
    ? heroImageAsset.width
    : projectData.imageWidth
const heroImageHeight =
  typeof heroImageAsset === 'object' &&
  heroImageAsset !== null &&
  'height' in heroImageAsset
    ? heroImageAsset.height
    : projectData.imageHeight
const remoteGalleryImages = projectData.eventGallery
  ? projectData.gallery.length > 0
    ? projectData.gallery.filter(
        (
          image,
        ): image is Extract<
          (typeof projectData.gallery)[number],
          { filename: string }
        > => 'filename' in image,
      )
    : (eventGalleries[project.id] ?? [])
  : []
const galleryImages = projectData.eventGallery
  ? []
  : projectData.gallery.map((image) => ({
      ...image,
      src: image.src as ImageMetadata,
    }))
const hasBody = Boolean(project.body?.trim())
const canonicalUrl = new URL(`/portfolio/${project.id}/`, Astro.site).toString()
const socialImageUrl =
  typeof heroImage === 'string'
    ? heroImage
    : new URL(heroImage.src, Astro.site).toString()
const projectTitle =
  projectData.seoTitle ?? `${projectData.title} - Ayoub Abedrabbo`
const projectDescription = projectData.seoDescription ?? projectData.summary
const sitemapUrl = new URL('/sitemap-index.xml', Astro.site).toString()
const comparisonVideos = projectData.videos.filter(
  (video) => video.comparisonRole,
)
const milestoneVideos = projectData.videos.filter(
  (video) => !video.comparisonRole && video.youtubeId !== projectData.heroVideo,
)
const isYaHalaProject = project.id === 'ya-hala'
const bayaanLandscapeImages = new Set([
  'Bayaan Academy students standing together onstage during a fundraising event',
  'Bayaan Academy students and adults gathered onstage during a fundraising event',
])
const bayaanGalleryGroups = galleryImages.reduce<
  Array<
    | { type: 'portraits'; images: typeof galleryImages }
    | { type: 'landscape'; image: (typeof galleryImages)[number] }
  >
>((groups, image) => {
  if (bayaanLandscapeImages.has(image.alt)) {
    groups.push({ type: 'landscape', image })
    return groups
  }

  const lastGroup = groups.at(-1)
  if (lastGroup?.type === 'portraits') {
    lastGroup.images.push(image)
  } else {
    groups.push({ type: 'portraits', images: [image] })
  }

  return groups
}, [])
const formatVideoDate = (date: string) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(`${date}T00:00:00Z`))
const hasDetails = Boolean(
  projectData.role ||
  projectData.collaborators.length ||
  projectData.duration ||
  projectData.tools.length,
)
const galleryHeading =
  projectData.galleryHeading ??
  (project.id === 'bayaan-academy' || project.id === 'arqam-academy'
    ? 'Photography'
    : 'Additional visuals')
---

<BaseLayout
  title={projectTitle}
  description={projectDescription}
  canonicalUrl={canonicalUrl}
  ogImage={socialImageUrl}
  ogImageAlt={heroImageAlt}
  ogType="article"
  robots="index,follow,max-image-preview:large"
  sitemapUrl={sitemapUrl}
  preconnectHints={['https://api.fontshare.com', 'https://i.ytimg.com']}
>
  <main
    id="main-content"
    class="mx-auto w-full max-w-screen-xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8"
  >
    <header class="mx-auto max-w-4xl" data-reveal="fade">
      <Breadcrumb>
        <BreadcrumbList>
          <BreadcrumbItem>
            <BreadcrumbLink
              href="/#portfolio"
              className="focus-visible:ring-ring rounded-sm focus-visible:ring-2 focus-visible:outline-none"
            >
              Portfolio
            </BreadcrumbLink>
          </BreadcrumbItem>
          <BreadcrumbSeparator />
          <BreadcrumbItem>
            <BreadcrumbPage>{projectData.title}</BreadcrumbPage>
          </BreadcrumbItem>
        </BreadcrumbList>
      </Breadcrumb>
    </header>

    <article class="pt-8 pb-12 sm:pt-12 lg:pb-20">
      <div data-reveal="up">
        {
          projectData.heroVideo ? (
            <YouTubeEmbed
              youtubeId={projectData.heroVideo}
              title={`${projectData.title} featured video`}
              poster={heroImage}
              posterAlt={heroImageAlt}
            />
          ) : typeof heroImage === 'string' ? (
            <Image
              src={heroImage}
              alt={heroImageAlt}
              width={heroImageWidth}
              height={heroImageHeight}
              layout="full-width"
              widths={[640, 960, 1280, 1600]}
              sizes="(min-width: 1280px) 1216px, 100vw"
              quality={82}
              priority
              class="bg-muted block h-auto w-full"
            />
          ) : (
            <Image
              src={heroImage}
              alt={heroImageAlt}
              width={heroImageWidth}
              height={heroImageHeight}
              layout="full-width"
              widths={[640, 960, 1280, 1600]}
              sizes="(min-width: 1280px) 1216px, 100vw"
              quality={82}
              priority
              class="bg-muted block h-auto w-full"
            />
          )
        }
      </div>

      <div class="mx-auto max-w-4xl py-10 sm:py-14" data-reveal="up">
        <p class="text-primary text-xs font-bold tracking-wider uppercase">
          {projectData.category}
        </p>
        <h1
          class="font-heading mt-3 text-4xl leading-none font-extrabold tracking-tight sm:text-5xl lg:text-6xl"
        >
          {projectData.title}
        </h1>
        <p
          class="text-muted-foreground mt-6 max-w-3xl text-lg leading-8 sm:text-xl"
        >
          {projectData.summary}
        </p>
      </div>

      {
        hasBody && (
          <section
            class="typeset typeset-portfolio mx-auto max-w-4xl py-8 sm:py-10"
            data-reveal="up"
          >
            <Content />
          </section>
        )
      }

      {
        projectData.location && (
          <PortfolioLocation
            title={projectData.title}
            {...projectData.location}
          />
        )
      }

      {
        projectData.services.length > 0 && (
          <section
            class="mx-auto max-w-4xl py-8 sm:py-10"
            aria-labelledby="services-title"
            data-reveal="up"
          >
            <h2 id="services-title" class="font-heading text-2xl font-bold">
              Work
            </h2>
            <ul class="mt-5 grid gap-x-8 gap-y-3 sm:grid-cols-2">
              {projectData.services.map((service) => (
                <li class="py-1 leading-snug font-semibold">{service}</li>
              ))}
            </ul>
          </section>
        )
      }

      {
        hasDetails && (
          <section
            class="mx-auto max-w-4xl py-8 sm:py-10"
            aria-labelledby="details-title"
            data-reveal="up"
          >
            <h2 id="details-title" class="font-heading text-2xl font-bold">
              Details
            </h2>
            <dl class="mt-5 grid gap-6 sm:grid-cols-2">
              {projectData.role && (
                <div>
                  <dt class="text-muted-foreground text-xs font-semibold tracking-wider uppercase">
                    Role
                  </dt>
                  <dd class="mt-1 font-semibold">{projectData.role}</dd>
                </div>
              )}
              {projectData.collaborators.length > 0 && (
                <div>
                  <dt class="text-muted-foreground text-xs font-semibold tracking-wider uppercase">
                    Collaborators
                  </dt>
                  <dd class="mt-1 font-semibold">
                    {projectData.collaborators.join(', ')}
                  </dd>
                </div>
              )}
              {projectData.duration && (
                <div>
                  <dt class="text-muted-foreground text-xs font-semibold tracking-wider uppercase">
                    Duration
                  </dt>
                  <dd class="mt-1 font-semibold">{projectData.duration}</dd>
                </div>
              )}
              {projectData.tools.length > 0 && (
                <div>
                  <dt class="text-muted-foreground text-xs font-semibold tracking-wider uppercase">
                    Tools
                  </dt>
                  <dd class="mt-1 font-semibold">
                    {projectData.tools.join(', ')}
                  </dd>
                </div>
              )}
            </dl>
          </section>
        )
      }

      {
        comparisonVideos.length > 0 && (
          <section
            class="mx-auto max-w-4xl py-8 sm:py-10"
            aria-labelledby="comparison-title"
            data-reveal="up"
          >
            <p class="text-primary text-xs font-bold tracking-wider uppercase">
              Production comparison
            </p>
            <h2
              id="comparison-title"
              class="font-heading mt-2 text-2xl font-bold"
            >
              Before and after
            </h2>
            <p class="text-muted-foreground mt-3 max-w-3xl leading-7">
              These episodes show the change in recording, lighting, color, and
              sound quality from before our partnership to the current
              production workflow.
            </p>

            <div class="mt-7 grid gap-8 lg:grid-cols-2">
              {comparisonVideos.map((video, index) => (
                <article
                  class="flex flex-col gap-4"
                  data-reveal="up"
                  style={`--reveal-delay: ${Math.min(index, 4) * 60}ms`}
                >
                  <div>
                    <p class="text-primary text-xs font-bold tracking-wider uppercase">
                      {video.label}
                    </p>
                    <p class="text-muted-foreground mt-1 text-sm font-medium">
                      {formatVideoDate(video.publishedAt)}
                    </p>
                  </div>
                  <YouTubeEmbed
                    youtubeId={video.youtubeId}
                    title={`${video.label}: ${video.title}`}
                  />
                  <p class="text-muted-foreground leading-7">
                    {video.description}
                  </p>
                </article>
              ))}
            </div>
          </section>
        )
      }

      {
        milestoneVideos.length > 0 && (
          <section
            class="mx-auto max-w-4xl py-8 sm:py-10"
            aria-labelledby="milestones-title"
            data-reveal="up"
          >
            <h2 id="milestones-title" class="font-heading text-2xl font-bold">
              {isYaHalaProject
                ? 'First collaborations'
                : milestoneVideos.length > 1
                  ? 'Featured videos'
                  : 'Featured video'}
            </h2>
            <p class="text-muted-foreground mt-3 max-w-3xl leading-7">
              {isYaHalaProject
                ? 'These October 2025 uploads mark the beginning of my production work with Ya Hala.'
                : 'Watch the finished production directly from the client project.'}
            </p>
            {isYaHalaProject ? (
              <ol class="mt-6 grid gap-6 sm:grid-cols-2">
                {milestoneVideos.map((video, index) => (
                  <li
                    data-reveal="up"
                    style={`--reveal-delay: ${Math.min(index, 4) * 60}ms`}
                  >
                    <a
                      href={`https://www.youtube.com/watch?v=${video.youtubeId}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group focus-visible:ring-ring block rounded-sm focus-visible:ring-2 focus-visible:outline-none"
                    >
                      <div class="bg-muted relative aspect-video overflow-hidden">
                        <Image
                          src={`https://i.ytimg.com/vi/${video.youtubeId}/mqdefault.jpg`}
                          alt={`Video thumbnail for ${video.title}`}
                          width={320}
                          height={180}
                          layout="constrained"
                          widths={[320, 480, 640]}
                          sizes="(min-width: 640px) 50vw, 100vw"
                          loading="lazy"
                          decoding="async"
                          class="size-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                        />
                        <span class="bg-background/90 text-foreground absolute inset-0 m-auto inline-flex size-12 items-center justify-center rounded-full shadow-sm">
                          <Play
                            className="size-5 fill-current"
                            aria-hidden="true"
                          />
                        </span>
                      </div>
                      <div class="py-4">
                        <div class="flex items-start justify-between gap-4">
                          <div>
                            <p class="font-bold">{video.label}</p>
                            <p class="text-muted-foreground mt-1 text-sm">
                              {formatVideoDate(video.publishedAt)}
                            </p>
                          </div>
                          <ArrowUpRight
                            className="mt-1 size-4 shrink-0"
                            aria-hidden="true"
                          />
                        </div>
                        <p class="text-muted-foreground mt-3 text-sm leading-6">
                          {video.description}
                        </p>
                      </div>
                    </a>
                  </li>
                ))}
              </ol>
            ) : (
              <div class="mt-6 space-y-8">
                {milestoneVideos.map((video, index) => (
                  <article
                    data-reveal="up"
                    style={`--reveal-delay: ${Math.min(index, 4) * 60}ms`}
                  >
                    <YouTubeEmbed
                      youtubeId={video.youtubeId}
                      title={`${video.label}: ${video.title}`}
                    />
                    <div class="py-4">
                      <p class="font-bold">{video.title}</p>
                      <p class="text-muted-foreground mt-1 text-sm">
                        {formatVideoDate(video.publishedAt)}
                      </p>
                      <p class="text-muted-foreground mt-3 leading-7">
                        {video.description}
                      </p>
                      <a
                        href={`https://www.youtube.com/watch?v=${video.youtubeId}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-primary mt-4 inline-flex font-bold underline underline-offset-4"
                      >
                        Watch {video.title} on YouTube
                      </a>
                    </div>
                  </article>
                ))}
              </div>
            )}
          </section>
        )
      }

      {
        projectData.upcomingVideo && (
          <UpcomingVideo {...projectData.upcomingVideo} />
        )
      }

      {
        projectData.outcomes.length > 0 && (
          <section
            class="mx-auto max-w-4xl py-8 sm:py-10"
            aria-labelledby="outcomes-title"
            data-reveal="up"
          >
            <h2 id="outcomes-title" class="font-heading text-2xl font-bold">
              Outcomes
            </h2>
            <ul class="mt-5 grid gap-x-8 gap-y-3 sm:grid-cols-2">
              {projectData.outcomes.map((outcome) => (
                <li class="py-1 leading-snug font-semibold">{outcome}</li>
              ))}
            </ul>
          </section>
        )
      }

      {
        projectData.eventGallery && remoteGalleryImages.length > 0 ? (
          <aside
            class="mx-auto max-w-4xl py-8 sm:py-10"
            aria-labelledby="gallery-cta-title"
            data-reveal="up"
          >
            <Separator className="mb-8 sm:mb-10" />
            <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
              <div class="max-w-xl">
                <h2
                  id="gallery-cta-title"
                  class="font-heading text-2xl font-bold"
                >
                  View the event gallery
                </h2>
                <p class="text-muted-foreground mt-3 leading-7">
                  Browse all {remoteGalleryImages.length}{' '}
                  {remoteGalleryImages.length === 1
                    ? 'photograph'
                    : 'photographs'}
                  full screen, share individual shots, or download the full set.
                </p>
              </div>
              <div class="flex flex-col gap-2 sm:shrink-0">
                <a
                  href={`/galleries/${project.id}/`}
                  class={cn(
                    buttonVariants({ size: 'lg' }),
                    'w-full justify-center sm:w-auto',
                  )}
                >
                  Open gallery
                  <ArrowRight data-icon="inline-end" aria-hidden="true" />
                </a>
                {projectData.downloadAllUrl && (
                  <a
                    href={projectData.downloadAllUrl}
                    download
                    class={cn(
                      buttonVariants({ variant: 'outline', size: 'lg' }),
                      'w-full justify-center sm:w-auto',
                    )}
                  >
                    <Download data-icon="inline-start" aria-hidden="true" />
                    Download all
                  </a>
                )}
              </div>
            </div>
          </aside>
        ) : galleryImages.length > 0 ? (
          <section
            class="mx-auto max-w-4xl py-8 sm:py-10"
            aria-labelledby="gallery-title"
            data-reveal="up"
          >
            <h2 id="gallery-title" class="font-heading text-2xl font-bold">
              {galleryHeading}
            </h2>
            {projectData.galleryLayout === 'masonry' ? (
              <div class="mt-6 columns-1 gap-4 sm:columns-2">
                {galleryImages.map((image, index) => (
                  <figure
                    class="mb-6 break-inside-avoid"
                    data-reveal={index < 12 ? 'up' : undefined}
                    style={
                      index < 12
                        ? `--reveal-delay: ${Math.min(index, 8) * 35}ms`
                        : undefined
                    }
                  >
                    <Image
                      src={image.src}
                      alt={image.alt}
                      layout="full-width"
                      widths={[480, 768, 1024, 1280, 1600]}
                      sizes="(min-width: 640px) 50vw, 100vw"
                      quality={80}
                      loading="lazy"
                      decoding="async"
                      class="block h-auto w-full"
                    />
                    {image.caption && (
                      <figcaption class="text-muted-foreground mt-2 text-sm">
                        {image.caption}
                      </figcaption>
                    )}
                  </figure>
                ))}
              </div>
            ) : project.id === 'bayaan-academy' ? (
              <div class="mt-6 space-y-6">
                {bayaanGalleryGroups.map((group) =>
                  group.type === 'landscape' ? (
                    <figure data-reveal="up">
                      <Image
                        src={group.image.src}
                        alt={group.image.alt}
                        layout="full-width"
                        widths={[640, 960, 1280, 1600]}
                        sizes="(min-width: 1280px) 896px, 100vw"
                        quality={80}
                        loading="lazy"
                        class="block h-auto w-full"
                      />
                      {group.image.caption && (
                        <figcaption class="text-muted-foreground mt-2 text-sm">
                          {group.image.caption}
                        </figcaption>
                      )}
                    </figure>
                  ) : (
                    <div class="columns-1 gap-4 sm:columns-2">
                      {group.images.map((image, index) => (
                        <figure
                          class="mb-6 break-inside-avoid"
                          data-reveal={index < 12 ? 'up' : undefined}
                          style={
                            index < 12
                              ? `--reveal-delay: ${Math.min(index, 8) * 35}ms`
                              : undefined
                          }
                        >
                          <Image
                            src={image.src}
                            alt={image.alt}
                            layout="full-width"
                            widths={[480, 768, 1024]}
                            sizes="(min-width: 640px) 50vw, 100vw"
                            quality={80}
                            loading="lazy"
                            class="block h-auto w-full"
                          />
                          {image.caption && (
                            <figcaption class="text-muted-foreground mt-2 text-sm">
                              {image.caption}
                            </figcaption>
                          )}
                        </figure>
                      ))}
                    </div>
                  ),
                )}
              </div>
            ) : project.id === 'arqam-academy' ? (
              <div class="mt-6 grid grid-cols-1 gap-x-4 gap-y-8 sm:grid-cols-2">
                {galleryImages.map((image, index) => (
                  <figure
                    data-reveal={index < 12 ? 'up' : undefined}
                    style={
                      index < 12
                        ? `--reveal-delay: ${Math.min(index, 8) * 35}ms`
                        : undefined
                    }
                  >
                    <Image
                      src={image.src}
                      alt={image.alt}
                      layout="full-width"
                      widths={[480, 768, 1024]}
                      sizes="(min-width: 640px) 50vw, 100vw"
                      quality={80}
                      loading="lazy"
                      class="block h-auto w-full"
                    />
                    {image.caption && (
                      <figcaption class="text-muted-foreground mt-2 text-sm">
                        {image.caption}
                      </figcaption>
                    )}
                  </figure>
                ))}
              </div>
            ) : (
              <div class="mt-6 space-y-8">
                {galleryImages.map((image, index) => (
                  <figure
                    data-reveal={index < 12 ? 'up' : undefined}
                    style={
                      index < 12
                        ? `--reveal-delay: ${Math.min(index, 8) * 35}ms`
                        : undefined
                    }
                  >
                    <Image
                      src={image.src}
                      alt={image.alt}
                      layout="full-width"
                      widths={[640, 960, 1280, 1600]}
                      sizes="(min-width: 1280px) 896px, 100vw"
                      quality={80}
                      loading="lazy"
                      class="block h-auto w-full"
                    />
                    {image.caption && (
                      <figcaption class="text-muted-foreground mt-2 text-sm">
                        {image.caption}
                      </figcaption>
                    )}
                  </figure>
                ))}
              </div>
            )}
          </section>
        ) : null
      }

      {
        projectData.links.length > 0 && (
          <>
            <Separator className="mx-auto max-w-4xl" />
            <section
              class="mx-auto max-w-4xl py-8 sm:py-10"
              aria-labelledby="links-title"
              data-reveal="up"
            >
              <h2 id="links-title" class="font-heading text-2xl font-bold">
                Project links
              </h2>
              <div class="mt-4 flex flex-col gap-1">
                {projectData.links.map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={cn(
                      buttonVariants({
                        variant: 'ghost',
                        size: 'lg',
                      }),
                      'h-auto w-full justify-between px-3 py-3 text-left font-bold whitespace-normal',
                    )}
                  >
                    <span>
                      {link.label === 'Website'
                        ? `${projectData.title} website`
                        : link.label}
                    </span>
                    <ArrowUpRight data-icon="inline-end" aria-hidden="true" />
                  </a>
                ))}
              </div>
            </section>
          </>
        )
      }

      {
        (previousProject || nextProject) && (
          <>
            <Separator className="mx-auto max-w-4xl" />
            <nav
              class="mx-auto grid max-w-4xl gap-2 pt-6 sm:grid-cols-2 sm:pt-8"
              aria-label="More portfolio projects"
              data-reveal="fade"
            >
              {previousProject && (
                <a
                  href={`/portfolio/${previousProject.id}/`}
                  aria-label={`Previous project: ${previousProject.title}`}
                  class={cn(
                    buttonVariants({
                      variant: 'ghost',
                      size: 'lg',
                    }),
                    'h-auto w-full justify-start px-3 py-3 text-left whitespace-normal',
                  )}
                >
                  <ArrowLeft data-icon="inline-start" aria-hidden="true" />
                  <span class="min-w-0">
                    <small class="text-muted-foreground block text-xs font-semibold tracking-wider uppercase">
                      Previous project
                    </small>
                    <span class="font-bold">{previousProject.title}</span>
                  </span>
                </a>
              )}
              {nextProject && (
                <a
                  href={`/portfolio/${nextProject.id}/`}
                  aria-label={`Next project: ${nextProject.title}`}
                  class={cn(
                    buttonVariants({
                      variant: 'ghost',
                      size: 'lg',
                    }),
                    'h-auto w-full justify-end px-3 py-3 text-right whitespace-normal sm:col-start-2',
                  )}
                >
                  <span class="min-w-0">
                    <small class="text-muted-foreground block text-xs font-semibold tracking-wider uppercase">
                      Next project
                    </small>
                    <span class="font-bold">{nextProject.title}</span>
                  </span>
                  <ArrowRight data-icon="inline-end" aria-hidden="true" />
                </a>
              )}
            </nav>
          </>
        )
      }
    </article>
  </main>
</BaseLayout>

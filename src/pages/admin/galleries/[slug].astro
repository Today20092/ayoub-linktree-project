---
import '../../../styles.css'

import { getEntry } from 'astro:content'
import { env } from 'cloudflare:workers'
import { ArrowLeft, ExternalLink } from 'lucide-react'

import AdminGallery from '../../../components/AdminGallery'
import { Button } from '../../../components/ui/button'
import { eventGalleries } from '../../../data/event-galleries'
import { galleryAdminAuthorized } from '../../../lib/gallery-admin'
import {
  getEventGallery,
  getGallerySettings,
  getHiddenFilenames,
  listGalleryInvites,
  listGalleryPhotos,
  listGuestPhotos,
  publicEventFlyer,
} from '../../../lib/gallery-data'
import BaseLayout from '../../../layouts/BaseLayout.astro'

export const prerender = false

if (
  !(await galleryAdminAuthorized(
    Astro.request,
    env.GALLERY_ADMIN_EMAIL,
    env.GALLERY_ACCESS_TEAM_DOMAIN,
    env.GALLERY_ACCESS_AUDS,
  ))
) {
  return new Response('Forbidden', { status: 403 })
}

const eventSlug = Astro.params.slug
const staticEvent = eventSlug
  ? await getEntry('portfolio', eventSlug)
  : undefined
const event = staticEvent?.data.eventGallery ? staticEvent : undefined
const dynamicEvent = eventSlug
  ? await getEventGallery(env.GALLERY_DB, eventSlug)
  : undefined
if ((!event && !dynamicEvent) || !eventSlug) {
  return new Response(null, { status: 404 })
}

const [settings, guests, hiddenFilenames, uploadedPhotos, invites] =
  await Promise.all([
    getGallerySettings(env.GALLERY_DB, eventSlug),
    listGuestPhotos(env.GALLERY_DB, eventSlug),
    getHiddenFilenames(env.GALLERY_DB, eventSlug),
    listGalleryPhotos(env.GALLERY_DB, eventSlug),
    listGalleryInvites(env.GALLERY_DB, eventSlug),
  ])
const inlineImages = event
  ? event.data.gallery.filter(
      (
        image,
      ): image is Extract<
        (typeof event.data.gallery)[number],
        { filename: string }
      > => 'filename' in image,
    )
  : []
const professionalImages =
  inlineImages.length > 0 ? inlineImages : (eventGalleries[eventSlug] ?? [])
const professional = professionalImages.map((image) => ({
  src: image.src,
  alt: image.alt,
  filename: image.filename,
  hidden: hiddenFilenames.has(image.filename),
}))
const ogImage =
  (dynamicEvent ? publicEventFlyer(dynamicEvent)?.src : undefined) ??
  (event
    ? typeof event.data.featuredImage === 'string'
      ? event.data.featuredImage
      : event.data.featuredImage.src
    : '/og.jpg')
const eventTitle = event?.data.title ?? dynamicEvent?.title ?? 'Event gallery'
const eventMeta = {
  title: eventTitle,
  summary:
    event?.data.galleryDescription ??
    event?.data.summary ??
    dynamicEvent?.summary ??
    '',
  category:
    event?.data.category ?? dynamicEvent?.category ?? 'Event Photography',
  eventDate:
    event?.data.eventDate?.toISOString().slice(0, 10) ??
    dynamicEvent?.event_date ??
    '',
  eventTime: event?.data.eventTime ?? dynamicEvent?.event_time ?? '',
  eventVenue: event?.data.eventVenue ?? dynamicEvent?.event_venue ?? '',
  comingSoon: dynamicEvent ? Boolean(dynamicEvent.coming_soon) : false,
  visibilityStatus: dynamicEvent?.status ?? 'published',
}

Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow')
---

<BaseLayout
  title={`Manage ${eventTitle}`}
  description={`Review guest uploads and curate ${eventTitle}.`}
  canonicalUrl={new URL(
    `/admin/galleries/${eventSlug}/`,
    Astro.site,
  ).toString()}
  ogImage={ogImage}
  ogImageAlt={eventTitle}
>
  <main
    id="main-content"
    class="mx-auto w-full max-w-screen-xl scroll-mt-20 px-4 py-10 sm:px-6 lg:px-8"
  >
    <div class="flex flex-wrap items-center justify-between gap-3">
      <Button variant="ghost" size="sm" asChild>
        <a href="/admin/galleries/">
          <ArrowLeft data-icon="inline-start" aria-hidden="true" />
          All galleries
        </a>
      </Button>
      <Button variant="outline" size="sm" asChild>
        <a href={`/galleries/${eventSlug}/`} target="_blank">
          View public gallery
          <ExternalLink data-icon="inline-end" aria-hidden="true" />
        </a>
      </Button>
    </div>

    <header class="mt-8 max-w-3xl">
      <p class="text-primary text-sm font-bold tracking-wide uppercase">
        Gallery administration
      </p>
      <h1
        class="font-heading mt-3 text-4xl leading-none font-extrabold tracking-tight sm:text-5xl"
      >
        {eventTitle}
      </h1>
      <p class="text-muted-foreground mt-4 text-lg leading-8">
        Review guest submissions, control upload access, and hide professional
        photos from the live gallery.
      </p>
    </header>

    <div class="mt-10">
      <AdminGallery
        client:only="react"
        eventSlug={eventSlug}
        eventMeta={eventMeta}
        settings={settings}
        guests={guests}
        uploadedPhotos={uploadedPhotos}
        invites={invites}
        professional={professional}
      />
    </div>
  </main>
</BaseLayout>

    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.8",
    "astro-icon": "^1.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.10.0",

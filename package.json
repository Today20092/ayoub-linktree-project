{
  "name": "ayoub-linktree-project",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "predev": "node scripts/copy-face-models.mjs",
    "dev": "astro dev",
    "start": "astro dev",
    "update:youtube": "node scripts/update-latest-youtube-video.mjs",
    "gallery:manifest": "node scripts/generate-event-gallery-manifest.mjs",
    "gallery:prune": "node scripts/prune-gallery.mjs",
    "test:gallery-prune": "node --test scripts/gallery-prune-core.test.mjs",
    "faces:index": "node scripts/face-index.mjs",
    "faces:review": "node scripts/face-review-server.mjs",
    "faces:publish": "node scripts/face-publish.mjs",
    "faces:delete": "node scripts/face-delete.mjs",
    "test:faces": "node --test scripts/face-index-core.test.mjs && tsx --test src/lib/face-search.test.ts",
    "prebuild": "node scripts/copy-face-models.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:prod": "npm audit --omit=dev",
    "verify": "npm run format:check && npm run test:faces && npm run check && npm run build",
    "astro": "astro",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.1",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@iconify-json/fa-brands": "^1.2.2",
    "@iconify-json/simple-icons": "^1.2.83",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vladmandic/human": "^3.3.6",
    "astro": "^7.0.2",
    "astro-icon": "^1.1.5",
    "class-variance-authority": "^0.7.1",
    "client-zip": "^2.5.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "prettier": "^3.1.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.11.1",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.105.0"
  }
}
